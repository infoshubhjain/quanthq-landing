  vline.style.opacity = 0;
  svg.appendChild(vline);
  const tip = document.createElement('div');
  tip.className = 'spark-tip';
  wrap.appendChild(tip);
  wrap.addEventListener('mousemove', e => {
    const r = wrap.getBoundingClientRect();
    const frac = Math.max(0, Math.min(1, (e.clientX - r.left)/r.width));
    const idx = Math.round(frac*(data.length-1));
    const x = idx/(data.length-1)*200;
    vline.setAttribute('x1', x); vline.setAttribute('x2', x);
    vline.style.opacity = 1;
    tip.textContent = fmt(data[idx]);
    tip.style.left = (frac*100)+'%';
    tip.style.opacity = 1;
  }, {passive:true});
  wrap.addEventListener('mouseleave', () => { vline.style.opacity = 0; tip.style.opacity = 0; });
}
sparkHover('spx-line', spxData, v => v.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ','));
sparkHover('vix-line', vixData, v => v.toFixed(1));

/* ── TICKER TAPE ── */
const tapeTrack = document.getElementById('tape-track');
if (tapeTrack) {
  const tapeItem = t => `<span class="tape-item"><span class="tape-sym">${t.sym}</span><span class="tape-px">${t.price}</span><span class="tape-chg ${t.dir}">${t.chg}</span></span>`;
  tapeTrack.innerHTML = [...tickers, ...tickers].map(tapeItem).join('');
  if (!reduced) setInterval(() => {
    // nudge one random symbol so the tape feels live
    const items = tapeTrack.querySelectorAll('.tape-item');
    const i = Math.floor(Math.random()*tickers.length);
    const t = tickers[i];
    const delta = (Math.random()-0.48)*0.4;
    const chg = (parseFloat(t.chg) + delta);
    t.chg = (chg>=0?'+':'')+chg.toFixed(1)+'%';
    t.dir = chg>=0?'up':'down';
    [items[i], items[i+tickers.length]].forEach(el => {
      if (!el) return;
      const c = el.querySelector('.tape-chg');
      c.textContent = t.chg;
      c.className = 'tape-chg '+t.dir;
    });
  }, 2600);
}

/* ── HUD CLOCK ── */
const hudClock = document.getElementById('hud-clock');
if (hudClock) {
  const tickClock = () => {
    const d = new Date();
    hudClock.textContent = 'UTC ' + d.toISOString().slice(11,19) + ' · SPX ' +
      spxData[spxData.length-1].toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,',');
  };
  tickClock();
  setInterval(tickClock, 1000);
}

/* ── HERO METRIC FLICKER removed ── */

/* ── THEME TOGGLE ── */
document.getElementById('theme-toggle')?.addEventListener('click', () => {
  const light = document.documentElement.classList.toggle('light');
  localStorage.theme = light ? 'light' : 'dark';
  document.getElementById('favicon').href = light ? FAVICON_LIGHT : FAVICON_DARK;
  if (reduced) drawGlobe(); // static canvases need one repaint in the new palette
});

/* ── PARALLAX ON SCROLL (merged into consolidated handler) ── */
if (!reduced) {
  const heroInner = document.querySelector('.hero-inner');
  const origOnScroll = onScroll;
  window.onScroll = function() {
    origOnScroll();
    if (heroInner) heroInner.style.transform = `translateY(${scrollY*0.15}px)`;
  };
  if (heroInner) heroInner.style.transform = 'translateY(0)';
}

/* ── COUNT-UP ANIMATION ── */
function countUp(el, target) {
  const dur = 1800;
  const start = performance.now();
  const fmt = n => n.toLocaleString();
  function step(now) {
    const t = Math.min((now - start) / dur, 1);
    const ease = 1 - Math.pow(1 - t, 3);
    el.textContent = fmt(Math.round(ease * target));
    if (t < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}
const countObserver = new IntersectionObserver(es => es.forEach(e => {
  if (!e.isIntersecting) return;
  const el = e.target;
  const target = +el.dataset.count;
  if (target) countUp(el, target);
  countObserver.unobserve(el);
}), {threshold:0.5});
document.querySelectorAll('[data-count]').forEach(el => countObserver.observe(el));

/* ── 3D TILT ON CARDS ── */
if (!reduced) {
  document.querySelectorAll('.bento-card, .hs-card').forEach(card => {
    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      const x = (e.clientX - r.left) / r.width;
      const y = (e.clientY - r.top) / r.height;
      const tiltX = (y - 0.5) * -8;
      const tiltY = (x - 0.5) * 8;
      card.style.transform = `perspective(600px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) translateY(-4px)`;
      card.style.setProperty('--mx', e.clientX - r.left + 'px');
      card.style.setProperty('--my', e.clientY - r.top + 'px');
    }, {passive:true});
    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
    });
  });
}

/* ── HERO TYPEWRITER EFFECT ── */
if (!reduced) {
  const twEl = document.getElementById('tw-text');
  const lines = ['QUANT','INTELLIGENCE','FOR THE','OBSESSED'];
  let li = 0, ci = 0;
  const styles = ['','color:var(--text-3)','', ''];
  function buildHTML(upToLine, upToChar) {
    let html = '';
    for (let i = 0; i <= upToLine; i++) {
      const text = i < upToLine ? lines[i] : lines[i].slice(0, upToChar);
      if (i === 1) html += '<span style="' + styles[1] + '">' + text + '</span>';
      // the last line is gradient-filled while it types — swapping the fill in
      // at the end made the word snap from solid white to gradient in one frame
      else if (i === 3) html += '<span class="grad-text">' + text + '</span>';
      else html += text;
      if (i < upToLine) html += '<br>';
    }
    return html;
  }
  function typeLine() {
    if (li >= lines.length) {
      twEl.innerHTML = buildHTML(3, lines[3].length);
      document.querySelector('.tw-cursor').style.display = 'none';
      return;
    }
    const line = lines[li];
    if (ci < line.length) {
      ci++;
      twEl.innerHTML = buildHTML(li, ci);
      setTimeout(typeLine, 55 + Math.random() * 35);
    } else {
      li++; ci = 0;
      setTimeout(typeLine, 180);
    }
  }
  setTimeout(typeLine, 800);
} else {
  document.getElementById('tw-text').innerHTML = 'QUANT<br><span style="color:var(--text-3)">INTELLIGENCE</span><br>FOR THE<br><span class="grad-text">OBSESSED</span>';
  document.querySelector('.tw-cursor').style.display = 'none';
}

/* ── FADE-IN-UP OBSERVER ── */
const fadeObserver = new IntersectionObserver(es => es.forEach(e => {
  if (e.isIntersecting) { e.target.classList.add('in'); fadeObserver.unobserve(e.target); }
}), {threshold:0, rootMargin:'0px 0px -40px 0px'});
document.querySelectorAll('.fade-in-up,.fade-in').forEach(el => fadeObserver.observe(el));

/* ── SECTION SCROLL DOTS ── */
const sections = ['hero','dashboard','research','network','terminal','join'];
const dots = document.querySelectorAll('.sd-dot');
const dotsContainer = document.getElementById('section-dots');
const sectionObserver = new IntersectionObserver(es => {
  es.forEach(e => {
    if (e.isIntersecting) {
      const idx = sections.indexOf(e.target.id);
      if (idx >= 0) dots.forEach((d,i) => d.classList.toggle('active', i === idx));
    }
  });
}, {threshold:0.3});
sections.forEach(id => {
  const el = document.getElementById(id) || document.querySelector(`.${id}`);
  if (el) sectionObserver.observe(el);
});
dots.forEach(d => d.addEventListener('click', () => {
  const t = document.getElementById(d.dataset.target);
  if (t) t.scrollIntoView({behavior:'smooth'});
}));
setTimeout(() => {
  if (scrollY > innerHeight * 0.5) dotsContainer.classList.add('visible');
}, 2000);
const dotsVisibilityObserver = new IntersectionObserver(es => {
  es.forEach(e => {
    dotsContainer.classList.toggle('visible', !e.isIntersecting);
  });
}, {threshold:0});
const heroSection = document.getElementById('hero') || document.querySelector('.hero');
if (heroSection) dotsVisibilityObserver.observe(heroSection);
</script>
</body>
</html>
