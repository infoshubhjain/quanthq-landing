/* canvases can't use CSS vars — resolve ink per frame from the active theme */
const isLight = () => document.documentElement.classList.contains('light');
const canvasInk = () => isLight() ? '15,23,42' : '255,255,255';

/* ── INTERACTIVE GLOBE (canvas port of 21st.dev Interactive Globe) ── */
const wCanvas = document.getElementById('world-canvas');
const wCtx = wCanvas.getContext('2d');
const GLOBE_H = 600;
const CITIES = [
  {name:'New York',lat:40.7,lon:-74.0},{name:'San Francisco',lat:37.8,lon:-122.4},
  {name:'Chicago',lat:41.9,lon:-87.6},{name:'São Paulo',lat:-23.5,lon:-46.6},
  {name:'London',lat:51.5,lon:-0.1},{name:'Zurich',lat:47.4,lon:8.5},
  {name:'Dubai',lat:25.2,lon:55.3},{name:'Mumbai',lat:19.1,lon:72.9},
  {name:'Singapore',lat:1.35,lon:103.8},{name:'Hong Kong',lat:22.3,lon:114.2},
  {name:'Tokyo',lat:35.7,lon:139.7},{name:'Sydney',lat:-33.9,lon:151.2},
];
const ARCS = [[0,4],[4,5],[4,6],[6,7],[7,8],[8,9],[9,10],[8,11],[0,3],[1,0],[2,0],[5,10]];
function ll2xyz(lat, lon) {
  const la = lat*Math.PI/180, lo = lon*Math.PI/180;
  return [Math.cos(la)*Math.cos(lo), Math.sin(la), Math.cos(la)*Math.sin(lo)];
}
const CITY_PTS = CITIES.map(c => ll2xyz(c.lat, c.lon));
// Fibonacci-distributed sphere dots
const SPHERE_DOTS = [];
for (let i = 0; i < 900; i++) {
  const ph = Math.acos(1 - 2*(i+0.5)/900), th = Math.PI*(1+Math.sqrt(5))*i;
  SPHERE_DOTS.push([Math.sin(ph)*Math.cos(th), Math.cos(ph), Math.sin(ph)*Math.sin(th)]);
}
let gRotY = -1.2, gRotX = -0.25, gDragging = false, gLastX = 0, gLastY = 0;
function gProject(p, R, cx, cy) {
  const cosY = Math.cos(gRotY), sinY = Math.sin(gRotY);
  const x1 = p[0]*cosY - p[2]*sinY, z1 = p[0]*sinY + p[2]*cosY;
  const cosX = Math.cos(gRotX), sinX = Math.sin(gRotX);
  const y2 = p[1]*cosX - z1*sinX, z2 = p[1]*sinX + z1*cosX;
  return [cx + x1*R, cy - y2*R, z2];
}
function gArcPoint(a, b, t) {
  const lift = 1 + 0.28*Math.sin(Math.PI*t);
  const x = a[0]+(b[0]-a[0])*t, y = a[1]+(b[1]-a[1])*t, z = a[2]+(b[2]-a[2])*t;
  const l = Math.hypot(x, y, z) || 1;
  return [x/l*lift, y/l*lift, z/l*lift];
}
function drawGlobe() {
  const W = wCanvas.offsetWidth;
  if (wCanvas.width !== W) wCanvas.width = W;
  if (wCanvas.height !== GLOBE_H) wCanvas.height = GLOBE_H;
  wCtx.clearRect(0, 0, W, GLOBE_H);
  const R = Math.min(W, GLOBE_H)*0.38, cx = W/2, cy = GLOBE_H/2;
  const t = Date.now()/1000;
  const ink = canvasInk();
  if (!gDragging) gRotY += 0.0022; // auto-rotate when idle
  // sphere dots, depth-shaded
  for (const d of SPHERE_DOTS) {
    const [sx, sy, z] = gProject(d, R, cx, cy);
    if (z <= 0.02) continue;
    wCtx.fillStyle = `rgba(${ink},${0.14 + z*0.42})`;
    wCtx.fillRect(sx, sy, 1.9, 1.9);
  }
  // arcs with traveling particles
  ARCS.forEach((arc, k) => {
    const A = CITY_PTS[arc[0]], B = CITY_PTS[arc[1]];
    wCtx.beginPath();
    let started = false;
    for (let s = 0; s <= 32; s++) {
      const [sx, sy, z] = gProject(gArcPoint(A, B, s/32), R, cx, cy);
      if (z > 0) {
        if (!started) { wCtx.moveTo(sx, sy); started = true; }
        else wCtx.lineTo(sx, sy);
      } else started = false;
    }
    wCtx.strokeStyle = `rgba(${ink},0.28)`;
    wCtx.lineWidth = 1;
    wCtx.stroke();
    const [px, py, pz] = gProject(gArcPoint(A, B, (t*0.12 + k*0.37) % 1), R, cx, cy);
    if (pz > 0) {
      wCtx.beginPath(); wCtx.arc(px, py, 1.8, 0, Math.PI*2);
      wCtx.fillStyle = isLight() ? 'rgba(37,99,235,0.95)' : 'rgba(123,162,255,0.95)'; wCtx.fill();
    }
  });
  // city markers with pulse rings + labels
  CITIES.forEach((c, i) => {
    const [sx, sy, z] = gProject(CITY_PTS[i], R, cx, cy);
    if (z <= 0) return;
    const pulse = Math.sin(t*2 + i)*0.5 + 0.5;
    wCtx.beginPath(); wCtx.arc(sx, sy, 2.5, 0, Math.PI*2);
    wCtx.fillStyle = `rgba(${ink},0.95)`; wCtx.fill();
    wCtx.beginPath(); wCtx.arc(sx, sy, 4 + pulse*5, 0, Math.PI*2);
    wCtx.strokeStyle = `rgba(${ink},${0.35*(1-pulse)})`;
    wCtx.lineWidth = 1; wCtx.stroke();
    if (z > 0.35) {
      wCtx.font = '9px Inter,sans-serif';
      wCtx.fillStyle = `rgba(${ink},${0.65*z})`;
      wCtx.fillText(c.name.toUpperCase(), sx + 8, sy + 3);
    }
  });
}
wCanvas.addEventListener('pointerdown', e => {
  gDragging = true; gLastX = e.clientX; gLastY = e.clientY;
  wCanvas.setPointerCapture(e.pointerId);
});
wCanvas.addEventListener('pointermove', e => {
  if (!gDragging) return;
  gRotY += (e.clientX - gLastX)*0.005;
  gRotX = Math.max(-0.9, Math.min(0.9, gRotX - (e.clientY - gLastY)*0.003));
  gLastX = e.clientX; gLastY = e.clientY;
});
wCanvas.addEventListener('pointerup', () => { gDragging = false; });
wCanvas.addEventListener('pointercancel', () => { gDragging = false; });
if (!reduced) {
  let wActive = false, wAnimId;
  function wLoop() {
    if (!wActive) return;
    drawGlobe();
    wAnimId = requestAnimationFrame(wLoop);
  }
  const wObserver = new IntersectionObserver(entries => {
    const vis = entries[0].isIntersecting;
    if (vis && !wActive) { wActive = true; wLoop(); }
    else if (!vis) { wActive = false; cancelAnimationFrame(wAnimId); }
  }, {threshold: 0.05});
  wObserver.observe(wCanvas);
} else {
  drawGlobe();
}

/* ── FORCE-DIRECTED GRAPH ── */
const fc = document.getElementById('force-canvas');
const fctx = fc.getContext('2d');
let fW, fH;
// node palette per theme: Research=blue, Paper=violet, Agent=cyan, Signal=neutral
const nodePalette = () => isLight()
  ? ['rgba(37,99,235,0.85)','rgba(109,40,217,0.85)','rgba(8,145,178,0.85)','rgba(15,23,42,0.45)']
  : ['rgba(122,158,255,0.9)','rgba(178,150,255,0.9)','rgba(0,255,240,0.75)','rgba(255,255,255,0.45)'];
let fNodes = [], fEdges = [];
function initForce() {
  fW = fc.width = fc.offsetWidth; fH = fc.height = 420;
  fNodes = Array.from({length:36}, (_,i) => ({
    x: fW/2 + (Math.random()-.5)*fW*0.7,
    y: fH/2 + (Math.random()-.5)*fH*0.7,
    vx:0, vy:0,
    r: 4+Math.random()*4.5,
    type: Math.floor(Math.random()*4),
    label: ['Momentum','Earnings NLP','Signal Ranker','Alpha Factor','Quality Score','Regime HMM','Backtest','LLM Agent','Quant Researcher','Factor Attribution','Sharpe Calc','Risk Model','VaR Engine','Portfolio Opt','Alt Data','Sentiment','Volatility','Order Flow','Cross-Section','Walk-Forward','Publication','Network Effect','Collaboration','Co-Author','Peer Review','Replication','Alpha Decay','Half-Life','Transaction Cost','Turnover','Capacity','Skewness','Kurtosis','Tail Risk','Drawdown','Recovery'][i],
  }));
  fEdges = [];
  for (let i=0;i<fNodes.length;i++) for (let j=i+1;j<fNodes.length;j++) {
    if (Math.random()<0.12) fEdges.push([i,j]);
  }
}
function stepForce() {
  const k = 80, repK = 4000, damping = 0.88;
  for (let i=0;i<fNodes.length;i++) {
    if (i === fDrag) continue; // dragged node follows the pointer, not physics
    let fx=0,fy=0;
    // repulsion
    for (let j=0;j<fNodes.length;j++) {
      if(i===j)continue;
      const dx=fNodes[i].x-fNodes[j].x, dy=fNodes[i].y-fNodes[j].y;
      const d=Math.max(1,Math.hypot(dx,dy));
      fx+=repK*dx/d/d; fy+=repK*dy/d/d;
    }
    // spring attraction on edges
    fEdges.forEach(([a,b])=>{
      if(a===i||b===i){
        const other=a===i?b:a;
        const dx=fNodes[i].x-fNodes[other].x, dy=fNodes[i].y-fNodes[other].y;
        const d=Math.max(1,Math.hypot(dx,dy));
        fx-=k*(d-100)*dx/d; fy-=k*(d-100)*dy/d;
      }
    });
    // center gravity
    fx += (fW/2-fNodes[i].x)*0.015;
    fy += (fH/2-fNodes[i].y)*0.015;
    fNodes[i].vx=(fNodes[i].vx+fx*0.001)*damping;
    fNodes[i].vy=(fNodes[i].vy+fy*0.001)*damping;
    fNodes[i].x+=fNodes[i].vx; fNodes[i].y+=fNodes[i].vy;
    fNodes[i].x=Math.max(20,Math.min(fW-20,fNodes[i].x));
    fNodes[i].y=Math.max(20,Math.min(fH-20,fNodes[i].y));
  }
}
let fMouseX = -1, fMouseY = -1, fHoverNode = -1, fDrag = -1;
fc.addEventListener('pointerdown', e => {
  const rect = fc.getBoundingClientRect();
  const x = e.clientX - rect.left, y = e.clientY - rect.top;
  for (let i=0; i<fNodes.length; i++) {
    if (Math.hypot(fNodes[i].x-x, fNodes[i].y-y) < 14) {
      fDrag = i;
      fc.setPointerCapture(e.pointerId);
      e.preventDefault();
      break;
    }
  }
});
fc.addEventListener('pointermove', e => {
  const rect = fc.getBoundingClientRect();
  fMouseX = e.clientX - rect.left;
  fMouseY = e.clientY - rect.top;
  if (fDrag >= 0) {
    const n = fNodes[fDrag];
    n.x = Math.max(20, Math.min(fW-20, fMouseX));
    n.y = Math.max(20, Math.min(fH-20, fMouseY));
    n.vx = n.vy = 0;
    fHoverNode = fDrag;
    return;
  }
  fHoverNode = -1;
  for (let i=0; i<fNodes.length; i++) {
    const d = Math.hypot(fNodes[i].x-fMouseX, fNodes[i].y-fMouseY);
    if (d < 12) { fHoverNode = i; break; }
  }
});
fc.addEventListener('pointerup', () => { fDrag = -1; });
fc.addEventListener('pointercancel', () => { fDrag = -1; });
fc.addEventListener('mouseleave', () => { fMouseX=-1; fMouseY=-1; fHoverNode=-1; });

function drawForce() {
  fctx.clearRect(0,0,fW,fH);
  stepForce();
  const ink = canvasInk();
  const palette = nodePalette();

  // Draw edges with hover highlighting
  fEdges.forEach(([a,b])=>{
    const na=fNodes[a],nb=fNodes[b];
    const isHovered = fHoverNode === a || fHoverNode === b;
    fctx.strokeStyle = isHovered ? `rgba(${ink},0.45)` : `rgba(${ink},0.16)`;
    fctx.lineWidth = isHovered ? 1.5 : 0.9;
    fctx.beginPath();fctx.moveTo(na.x,na.y);fctx.lineTo(nb.x,nb.y);fctx.stroke();
  });

  // Draw nodes with hover effects + label tooltip
  fNodes.forEach((n,i)=>{
    const c=palette[n.type];
    const isHovered = fHoverNode === i;
    const scale = isHovered ? 1.6 : 1;
    const glowRadius = isHovered ? n.r*8 : n.r*4;

    // Glow
    const grad=fctx.createRadialGradient(n.x,n.y,n.r,n.x,n.y,glowRadius);
    grad.addColorStop(0,c.replace(/[\d.]+\)$/,'0.20)'));
    grad.addColorStop(1,'transparent');
    fctx.beginPath();fctx.arc(n.x,n.y,glowRadius,0,Math.PI*2);
    fctx.fillStyle=grad;fctx.fill();

    // Node
    fctx.beginPath();fctx.arc(n.x,n.y,n.r*scale,0,Math.PI*2);
    fctx.fillStyle=c;fctx.fill();

    // Highlight ring + label on hover
    if (isHovered) {
      fctx.strokeStyle = `rgba(${ink},0.6)`;
      fctx.lineWidth = 1.5;
      fctx.beginPath();fctx.arc(n.x,n.y,n.r*scale+2,0,Math.PI*2);
      fctx.stroke();

      // Tooltip label
      const label = n.label;
      const padding = 8;
      fctx.font = '600 11px Inter, system-ui, sans-serif';
      const tw = fctx.measureText(label).width;
      const bx = Math.min(n.x - tw/2 - padding, fW - tw - padding*2 - 4);
      const by = n.y - n.r*scale - 36;
      const bxClamped = Math.max(4, bx);
      const byClamped = Math.max(4, by);

      // Tooltip background
      fctx.fillStyle = isLight() ? 'rgba(255,255,255,0.95)' : 'rgba(9,13,21,0.92)';
      fctx.beginPath();
      fctx.roundRect(bxClamped, byClamped, tw + padding*2, 24, 4);
      fctx.fill();

      // Tooltip border
      fctx.strokeStyle = `rgba(${ink},0.3)`;
      fctx.lineWidth = 1;
      fctx.beginPath();
      fctx.roundRect(bxClamped, byClamped, tw + padding*2, 24, 4);
      fctx.stroke();

      // Tooltip text
      fctx.fillStyle = c;
      fctx.fillText(label, bxClamped + padding, byClamped + 16);
    }
  });
}
if (!reduced) {
  initForce();

  // Pause force graph when off-screen
  let fActive = false;
  let fAnimId;
  function fLoop() {
    if (!fActive) return;
    drawForce();
    fAnimId = requestAnimationFrame(fLoop);
  }
  const fObserver = new IntersectionObserver(entries => {
    const vis = entries[0].isIntersecting;
    if (vis && !fActive) { fActive = true; fLoop(); }
    else if (!vis) { fActive = false; cancelAnimationFrame(fAnimId); }
  }, {threshold: 0.05});
  fObserver.observe(fc);

  // reassigning canvas.width wipes the bitmap; if the loop is paused (off-screen)
  // nothing would repaint it, leaving a blank panel until you scroll away and back.
  addEventListener('resize', ()=>{ initForce(); if (!fActive) drawForce(); }, {passive:true});
}

