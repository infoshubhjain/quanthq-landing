---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const papers = (await getCollection('research')).sort((a, b) => +b.data.date - +a.data.date).slice(0, 3);
const posts = (await getCollection('blog')).sort((a, b) => +b.data.date - +a.data.date).slice(0, 2);
---
<Base title="QuantHQ — AI Research Institution for Quantitative Finance">
  <section class="min-h-[80vh] flex items-center px-6">
    <div class="max-w-6xl mx-auto w-full">
      <div class="section-label mb-8">AI Research Institution</div>
      <h1 class="text-[clamp(52px,9vw,120px)] font-extrabold leading-[0.95] tracking-[-0.04em]">
        QUANT<br /><span class="text-white/30">INTELLIGENCE</span><br />FOR THE<br /><span class="gradient-text">OBSESSED</span>
      </h1>
      <p class="mt-10 max-w-md text-white/45 leading-relaxed">
        Not a community. Not a platform. A living research ecosystem built for the people who spend their weekends reading papers.
      </p>
      <div class="mt-9 flex gap-4">
        <a href="/research/" class="px-7 py-3.5 rounded bg-gradient-to-br from-neon to-violet text-black text-[13px] font-bold uppercase tracking-wide hover:-translate-y-0.5 transition-transform">View Research</a>
        <a href="/about/" class="px-7 py-3.5 rounded border border-white/12 text-white/60 text-[13px] font-medium hover:border-white/30 hover:text-white/90 transition-colors">About us</a>
      </div>
    </div>
  </section>

  <section class="px-6 mt-24">
    <div class="max-w-6xl mx-auto">
      <div class="section-label mb-5">Latest Research</div>
      <div class="grid md:grid-cols-3 gap-4">
        {papers.map((p) => (
          <a href={`/research/${p.id}/`} class="card p-7 block rv">
            <span class="text-[9px] uppercase tracking-[0.2em] px-2.5 py-1 rounded-full border border-neon/20 text-neon font-semibold">{p.data.tags[0] ?? 'Research'}</span>
            <h3 class="mt-4 font-semibold text-white/85 leading-snug">{p.data.title}</h3>
            <p class="mt-3 text-[13px] text-white/35 leading-relaxed line-clamp-3">{p.data.abstract}</p>
            <div class="mt-5 text-[11px] text-white/25">{p.data.authors.join(' · ')}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="px-6 mt-24">
    <div class="max-w-6xl mx-auto">
      <div class="section-label mb-5">From the Blog</div>
      <div class="grid md:grid-cols-2 gap-4">
        {posts.map((p) => (
          <a href={`/blog/${p.id}/`} class="card p-7 block rv">
            <span class="text-[10px] uppercase tracking-[0.15em] text-violet font-semibold">{p.data.category}</span>
            <h3 class="mt-3 text-lg font-semibold text-white/85">{p.data.title}</h3>
            <p class="mt-2 text-[13px] text-white/35">{p.data.description}</p>
            <div class="mt-4 text-[11px] text-white/25">{p.data.author} · {p.data.readingTime}</div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
