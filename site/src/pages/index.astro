function sparkHover(lineId, data, fmt) {
  const line = document.getElementById(lineId);
  const wrap = line.closest('.bb-chart-line');
  const svg = line.ownerSVGElement;
  const vline = document.createElementNS('http://www.w3.org/2000/svg', 'line');
  vline.setAttribute('y1', 0); vline.setAttribute('y2', 48);
  vline.style.stroke = 'var(--text-2)';
