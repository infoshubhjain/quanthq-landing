<script>
const reduced = matchMedia('(prefers-reduced-motion:reduce)').matches;

/* ── LOADER ── */
(function(){
  const bar = document.getElementById('lbar');
  const loader = document.getElementById('loader');
  // Cap total loader time at ~600ms
  const start = performance.now();
  const iv = setInterval(() => {
    const p = Math.min(100, ((performance.now() - start) / 500) * 100);
    bar.style.width = p + '%';
    if (p >= 100) {
      clearInterval(iv);
      loader.classList.add('hide');
      document.querySelector('.bgfx-grain')?.classList.add('active');
      setTimeout(()=>{loader.style.display='none'},600);
    }
  }, 40);
})();

/* ── HAMBURGER MENU ── */
const hamburger = document.getElementById('nav-hamburger');
const navLinks = document.getElementById('nav-links');
if (hamburger && navLinks) {
  hamburger.addEventListener('click', () => {
    const open = navLinks.classList.toggle('open');
    hamburger.classList.toggle('active', open);
    document.body.style.overflow = open ? 'hidden' : '';
  });
  // Close on nav link click
  navLinks.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      navLinks.classList.remove('open');
      hamburger.classList.remove('active');
      document.body.style.overflow = '';
    });
  });
}

/* ── CONSOLIDATED SCROLL HANDLER ── */
const sp = document.getElementById('scroll-prog');
const navEl = document.getElementById('nav');
const parallaxH2 = [...document.querySelectorAll('.section-h2')];
let ticking = false;
function onScroll() {
  const h = document.documentElement;
  sp.style.width = (scrollY / (h.scrollHeight - h.clientHeight) * 100) + '%';
  navEl.classList.toggle('scrolled', scrollY > 40);
  // heading parallax — measure the untransformed parent so it doesn't feed back
  for (const el of parallaxH2) {
    const r = el.parentElement.getBoundingClientRect();
    if (r.bottom < 0 || r.top > innerHeight) continue;
    el.style.transform = `translateY(${(r.top + r.height/2 - innerHeight/2) * 0.07}px)`;
  }
  ticking = false;
}
addEventListener('scroll', () => {
  if (!ticking) { requestAnimationFrame(onScroll); ticking = true; }
}, {passive:true});

/* ── REVEAL ── */
/* terminal-style decode effect for labels */
function scrambleIn(el) {
  const orig = el.textContent;
  const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789$#%/';
  let f = 0;
  const iv = setInterval(() => {
    f++;
    el.textContent = orig.split('').map((c, i) =>
      i < f ? c : (c === ' ' ? ' ' : chars[Math.random()*chars.length|0])
    ).join('');
    if (f >= orig.length) clearInterval(iv);
  }, 26);
}
const rio = new IntersectionObserver(es => es.forEach(e => {
  if (e.isIntersecting) {
    e.target.classList.add('in');
    if (!reduced) e.target.querySelectorAll('.section-label').forEach(scrambleIn);
    rio.unobserve(e.target);
  }
}), {threshold:0, rootMargin:'0px 0px -60px 0px'});
document.querySelectorAll('.rv2').forEach(el => rio.observe(el));
if (!reduced) setTimeout(() => scrambleIn(document.querySelector('.hero-eyebrow')), 500);

/* ── STAT COUNTERS — show actual numbers, animate on scroll ── */
document.querySelectorAll('[data-count]').forEach(el => {
  el.textContent = (+el.dataset.count).toLocaleString();
});
function animCount(el) {
  el.style.animation = 'statGlow 0.6s ease-out';
}
const cio = new IntersectionObserver(es => es.forEach(e => {
  if (!e.isIntersecting) return;
  animCount(e.target);
  cio.unobserve(e.target);
}), {threshold:0.5});
document.querySelectorAll('[data-count]').forEach(el => cio.observe(el));

/* ── BG PARTICLE CANVAS removed ── */

/* ── FLOATING OBJECTS removed ── */

/* ── BLOOMBERG DASHBOARD ── */
// Mini sparkline generator
function makePoints(n, base, variance) {
  let v = base, pts = [];
  for (let i=0; i<n; i++) {
    v += (Math.random()-.48)*variance;
    pts.push(Math.max(base*0.9, Math.min(base*1.1, v)));
  }
  return pts;
}
function toSVGPoints(arr, w, h) {
  const min = Math.min(...arr), max = Math.max(...arr), range = max-min||1;
  return arr.map((v,i) => `${i/(arr.length-1)*w},${h-(v-min)/range*h}`).join(' ');
}
let spxData = makePoints(40, 5847, 12);
let vixData = makePoints(40, 16.3, 0.4);
let sparkDrawing = false; // pause polyline swaps while the draw-in animation runs
function tweenNum(el, to, fmt) {
  const from = parseFloat(el.textContent.replace(/,/g,'')) || to;
  if (reduced || from === to) { el.textContent = fmt(to); return; }
  const start = performance.now(), dur = 400;
  (function step(now) {
    const t = Math.min((now - start) / dur, 1), e = 1 - Math.pow(1 - t, 3);
    el.textContent = fmt(from + (to - from) * e);
    if (t < 1) requestAnimationFrame(step);
  })(start);
}
function updateCharts() {
  spxData.push(spxData[spxData.length-1]+(Math.random()-.48)*8); spxData.shift();
  vixData.push(vixData[vixData.length-1]+(Math.random()-.48)*0.3); vixData.shift();
  const spxV = spxData[spxData.length-1];
  const vixV = vixData[vixData.length-1];
  tweenNum(document.getElementById('spx-val'), spxV, v => Math.round(v).toLocaleString('en-US'));
  tweenNum(document.getElementById('vix-val'), vixV, v => v.toFixed(1));
  document.getElementById('spx-time').textContent = new Date().toLocaleTimeString('en-US',{hour12:false});
  const spxPct = ((spxV/spxData[0]-1)*100).toFixed(2);
  const vixPct = ((vixV/vixData[0]-1)*100).toFixed(2);
  const spxEl = document.getElementById('spx-chg');
  spxEl.textContent = (spxPct>=0?'+':'')+spxPct+'%';
  spxEl.className = 'bb-change '+(spxPct>=0?'up':'down');
  const vixEl = document.getElementById('vix-chg');
  vixEl.textContent = (vixPct>=0?'+':'')+vixPct+'%';
  vixEl.className = 'bb-change '+(vixPct>=0?'up':'down');
  if (!sparkDrawing) {
    document.getElementById('spx-line').setAttribute('points', toSVGPoints(spxData,200,48));
    document.getElementById('vix-line').setAttribute('points', toSVGPoints(vixData,200,48));
  }
}
updateCharts();
if (!reduced) setInterval(updateCharts, 1800);

// Draw-in: sparklines trace themselves when the dashboard first scrolls into view
if (!reduced) {
  const sparkIO = new IntersectionObserver(es => {
    if (!es[0].isIntersecting) return;
    sparkIO.disconnect();
    sparkDrawing = true;
    const lines = ['spx-line','vix-line'].map(id => document.getElementById(id));
    lines.forEach(l => {
      const len = l.getTotalLength();
      l.style.strokeDasharray = len;
      l.style.strokeDashoffset = len;
      l.style.transition = 'stroke-dashoffset 1.2s var(--ease-out)';
      requestAnimationFrame(() => requestAnimationFrame(() => l.style.strokeDashoffset = 0));
    });
    setTimeout(() => {
      lines.forEach(l => { l.style.strokeDasharray = l.style.strokeDashoffset = l.style.transition = ''; });
      sparkDrawing = false;
    }, 1350);
  }, {threshold: 0.3});
  sparkIO.observe(document.querySelector('.bloomberg-grid'));
}

// Heatmap — color-mix over theme vars so cells read in both modes
const hmColors = [60,40,20].map(p=>`color-mix(in srgb,var(--green) ${p}%,transparent)`)
  .concat(['var(--border-hover)'], [20,40,60].map(p=>`color-mix(in srgb,var(--red) ${p}%,transparent)`));
const hmEl = document.getElementById('heatmap');
const sectors = ['Tech','Fin','Health','Energy','Cons','Util','Mat','RE','Comm','Ind','XLRE','ARKK','IWM','QQQ','SPY','DIA','TLT','GLD'];
const hmPcts = [2.4, 1.5, 0.6, 0.1, -0.6, -1.5, -2.4];
for (let i=0; i<21; i++) {
  const c = document.createElement('div');
  c.className = 'hm-cell';
  const ci = Math.floor(Math.random()*hmColors.length);
  c.style.background = hmColors[ci];
  c.style.animationDelay = (Math.random()*3)+'s';
  c.style.animationDuration = (2+Math.random()*3)+'s';
  c.title = sectors[i%sectors.length];
  c.dataset.sector = sectors[i%sectors.length];
  c.dataset.pct = (hmPcts[ci] + (Math.random()-0.5)*0.6).toFixed(1);
  hmEl.appendChild(c);
}
// click a cell → sector detail strip
const hmDetail = document.createElement('div');
hmDetail.className = 'hm-detail';
hmEl.after(hmDetail);
hmEl.addEventListener('click', e => {
  const cell = e.target.closest('.hm-cell');
  if (!cell) return;
  const was = cell.classList.contains('sel');
  hmEl.querySelectorAll('.sel').forEach(c => c.classList.remove('sel'));
  if (was) { hmDetail.textContent = ''; return; }
  cell.classList.add('sel');
  const p = +cell.dataset.pct;
  hmDetail.textContent = `${cell.dataset.sector.toUpperCase()} · ${p>=0?'+':''}${p}% today · ${Math.floor(Math.random()*40+12)} instruments tracked`;
});
// hover previews a sector in the detail strip (a pinned click wins)
hmEl.addEventListener('mouseover', e => {
  const cell = e.target.closest('.hm-cell');
  if (!cell || hmEl.querySelector('.sel')) return;
  const p = +cell.dataset.pct;
  hmDetail.textContent = `${cell.dataset.sector.toUpperCase()} · ${p>=0?'+':''}${p}% today`;
});
hmEl.addEventListener('mouseleave', () => {
  if (!hmEl.querySelector('.sel')) hmDetail.textContent = '';
});
// live repricing: one random cell re-colors with a flash every few seconds
if (!reduced) setInterval(() => {
  const c = hmEl.children[Math.floor(Math.random()*hmEl.children.length)];
  const ci = Math.floor(Math.random()*hmColors.length);
  c.style.background = hmColors[ci];
  c.dataset.pct = (hmPcts[ci] + (Math.random()-0.5)*0.6).toFixed(1);
  c.classList.remove('hm-flash');
  void c.offsetWidth;
  c.classList.add('hm-flash');
}, 2400);

// Ticker feed
const tickers = [
  {sym:'NVDA',price:'131.42',chg:'+2.8%',dir:'up'},
  {sym:'AAPL',price:'212.18',chg:'+1.4%',dir:'up'},
  {sym:'MSFT',price:'448.62',chg:'+0.4%',dir:'up'},
  {sym:'META',price:'562.90',chg:'+1.9%',dir:'up'},
  {sym:'TSLA',price:'189.34',chg:'-1.6%',dir:'down'},
  {sym:'BTC',price:'68,420',chg:'+3.1%',dir:'up'},
  {sym:'ETH',price:'3,840',chg:'+2.2%',dir:'up'},
  {sym:'VIX',price:'16.3',chg:'-2.1%',dir:'down'},
];
const tf = document.getElementById('ticker-feed');
tf.innerHTML = tickers.map(t=>`
  <div class="ticker-row" data-sym="${t.sym}">
    <span class="ticker-sym">${t.sym}</span>
    <span class="ticker-price">${t.price}</span>
    <span class="ticker-chg ${t.dir}">${t.chg}</span>
  </div>`).join('');
// Build ticker rows once, then update only changed values
const tickerRows = {};
tickers.forEach(t => {
  const row = tf.querySelector(`[data-sym="${t.sym}"]`);
  if (row) tickerRows[t.sym] = row;
});
// Re-grab after initial render
if (!reduced) {
  setInterval(()=>{
    const t = tickers[Math.floor(Math.random()*tickers.length)];
    const pct = parseFloat(t.chg)+(Math.random()-.5)*0.2;
    t.chg = (pct>=0?'+':'')+pct.toFixed(1)+'%';
    t.dir = pct>=0?'up':'down';
    // Update only the changed row's chg span efficiently
    const row = tf.querySelector(`.ticker-row[data-sym="${t.sym}"] .ticker-chg`);
    if (row) {
      row.textContent = t.chg;
      row.className = 'ticker-chg ' + t.dir;
      const tr = row.closest('.ticker-row');
      tr.classList.remove('flash-up','flash-down');
      void tr.offsetWidth;
      tr.classList.add(t.dir === 'up' ? 'flash-up' : 'flash-down');
    } else {
      // fallback: rebuild
      tf.innerHTML = tickers.map(t=>`
        <div class="ticker-row" data-sym="${t.sym}">
          <span class="ticker-sym">${t.sym}</span>
          <span class="ticker-price">${t.price}</span>
          <span class="ticker-chg ${t.dir}">${t.chg}</span>
        </div>`).join('');
    }
  }, 2200);
}

// Agent feed — dot color keyed to status
const agentColors = {running:'var(--green)',training:'var(--violet)',idle:'var(--text-4)'};
const agents = [
  {name:'alpha-extractor-v3',status:'running'},
  {name:'regime-classifier',status:'training'},
  {name:'earnings-nlp-agent',status:'idle'},
  {name:'backtest-engine-5d',status:'running'},
  {name:'signal-ranker',status:'running'},
].map(a=>({...a,color:agentColors[a.status]}));
document.getElementById('agent-feed').innerHTML = agents.map(a=>`
  <div class="agent-row">
    <div class="agent-dot" style="background:${a.color}"></div>
    <span class="agent-name">${a.name}</span>
    <span class="agent-status">[${a.status}]</span>
  </div>`).join('');

// Factor bars
const factors = [
  {name:'momentum_3m',val:0.72},
  {name:'earnings_rev',val:0.91},
  {name:'quality_score',val:0.68},
  {name:'short_interest',val:0.43},
  {name:'sentiment_nlp',val:0.56},
];
document.getElementById('factor-bars').innerHTML = factors.map(f=>`
  <div style="margin-bottom:8px">
    <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--text-3);margin-bottom:3px;letter-spacing:0.05em">
      <span>${f.name}</span><span>${f.val.toFixed(2)}</span>
    </div>
    <div style="height:3px;background:var(--border);border-radius:2px;overflow:hidden">
      <div style="height:100%;width:${f.val*100}%;background:var(--blue);border-radius:2px;transition:width 1s var(--ease-out)"></div>
    </div>
  </div>`).join('');

// Bento factor list — green for positive loadings, red for negative
document.getElementById('factor-list').innerHTML = [
  {n:'momentum_3m',v:'+0.72'},
  {n:'earnings_revision',v:'+0.91'},
  {n:'quality_score',v:'+0.68'},
  {n:'short_interest_δ',v:'-0.43'},
  {n:'value_spread',v:'+0.55'},
  {n:'sentiment_nlp',v:'+0.77'},
  {n:'insider_flow',v:'+0.49'},
  {n:'vol_carry',v:'-0.31'},
  {n:'analyst_dispersion',v:'+0.38'},
  {n:'liquidity_shock',v:'-0.22'},
].map(f=>`<div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);font-size:11px">
  <span style="color:var(--text-3);font-family:'Courier New',monospace">${f.n}</span>
  <span style="color:${f.v.startsWith('-')?'var(--red)':'var(--green)'};font-weight:600;font-family:'Courier New',monospace">${f.v}</span>
</div>`).join('');

