---
import Base from '../layouts/Base.astro';
const channels = [
  ['Discord', 'Real-time debate, market commentary, and strategy discussion.'],
  ['Hackathons', 'Quarterly quant hackathons with real datasets and prizes.'],
  ['Reading Groups', 'Weekly paper walkthroughs across factors, ML, and macro.'],
  ['Open Source', 'Contribute to the agent framework and research tooling.'],
];
---
<Base title="Community — QuantHQ">
  <section class="px-6 pt-20">
    <div class="max-w-6xl mx-auto">
      <div class="section-label mb-6">Global Network</div>
      <h1 class="text-[clamp(40px,6vw,80px)] font-extrabold tracking-[-0.04em] leading-none">Everywhere<br />intelligence lives.</h1>
      <div class="mt-14 grid md:grid-cols-2 gap-4">
        {channels.map(([t, d]) => (
          <div class="card p-8 rv">
            <h2 class="text-xl font-semibold text-white/90">{t}</h2>
            <p class="mt-3 text-sm text-white/40 leading-relaxed">{d}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 card p-10 text-center rv">
        <h2 class="text-2xl font-bold">Join the network</h2>
        <p class="mt-3 text-white/45 text-sm">200+ researchers, engineers, and students building in the open.</p>
        <a href="/contact/" class="inline-block mt-6 px-7 py-3.5 rounded bg-gradient-to-br from-neon to-violet text-black text-[13px] font-bold uppercase tracking-wide">Get involved</a>
      </div>
    </div>
  </section>
</Base>
