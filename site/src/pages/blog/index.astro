---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => +b.data.date - +a.data.date);
const categories = ['AI', 'Research', 'Engineering', 'Quantitative Finance', 'Opinion', 'Tutorials'];
---
<Base title="Blog — QuantHQ">
  <section class="px-6 pt-20 pb-8">
    <div class="max-w-6xl mx-auto">
      <div class="section-label mb-6">Writing</div>
      <h1 class="text-[clamp(40px,6vw,80px)] font-extrabold tracking-[-0.04em] leading-none">Blogs</h1>
      <p class="mt-5 text-[var(--text-2)] max-w-md">Approachable writing on AI, engineering, and quantitative finance.</p>
      <input id="blog-search" type="search" placeholder="Search articles…"
        class="mt-9 w-full max-w-lg px-5 py-3.5 rounded-lg bg-[var(--card-bg)] border border-[var(--border)] text-sm text-[var(--text)] placeholder:text-[var(--text-3)] focus:border-accent-40 focus:outline-none" />
      <div class="mt-5 flex flex-wrap gap-2">
        <button data-cat="" class="cat-btn px-4 py-1.5 rounded-full text-xs font-medium border border-accent2-50 text-[var(--accent2)]">All</button>
        {categories.map((c) => (
          <button data-cat={c} class="cat-btn px-4 py-1.5 rounded-full text-xs font-medium border border-[var(--border)] text-[var(--text-2)] hover:text-[var(--text-1)]">{c}</button>
        ))}
      </div>
    </div>
  </section>

  <section class="px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-4" id="blog-list">
      {posts.map((p, i) => (
        <a href={`/blog/${p.id}/`} class:list={['card p-8 block blog-item group', { 'md:col-span-2': i === 0 }]} data-cat={p.data.category} data-text={`${p.data.title} ${p.data.description}`.toLowerCase()}>
          {i === 0 && <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--accent2)] to-[var(--accent)]"></div>}
          <span class="text-[10px] uppercase tracking-[0.15em] text-[var(--accent2)] font-semibold">{p.data.category}</span>
          <h2 class:list={['font-semibold text-[var(--text-1)] leading-snug group-hover:text-[var(--text)] transition-colors', i === 0 ? 'mt-3 text-2xl' : 'mt-3 text-xl']}>{p.data.title}</h2>
          <p class="mt-3 text-sm text-[var(--text-2)] leading-relaxed">{p.data.description}</p>
          <div class="mt-5 flex items-center gap-3 text-[12px] text-[var(--text-3)]">
            <span class="text-[var(--text-2)] font-medium">{p.data.author}</span>
            <span>{p.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            {p.data.readingTime && <span class="ml-auto">{p.data.readingTime}</span>}
          </div>
        </a>
      ))}
    </div>
  </section>

  <script>
    const input = document.getElementById('blog-search');
    const items = [...document.querySelectorAll('.blog-item')];
    const btns = [...document.querySelectorAll('.cat-btn')];
    let cat = '';
    function apply() {
      const q = input.value.trim().toLowerCase();
      items.forEach((el) => {
        const ok = (!cat || el.dataset.cat === cat) && (!q || el.dataset.text.includes(q));
        el.style.display = ok ? '' : 'none';
      });
    }
    input?.addEventListener('input', apply);
    btns.forEach((b) => b.addEventListener('click', () => {
      cat = b.dataset.cat;
      btns.forEach((x) => {
        x.style.borderColor = '';
        x.style.color = '';
      });
      b.style.borderColor = 'var(--accent2)';
      b.style.color = 'var(--accent2)';
      apply();
    }));
  </script>
</Base>
