---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => +b.data.date - +a.data.date);
const categories = ['AI', 'Research', 'Engineering', 'Quantitative Finance', 'Opinion', 'Tutorials'];
---
<Base title="Blog — QuantHQ">
  <section class="px-6 pt-20 pb-8">
    <div class="max-w-6xl mx-auto">
      <div class="section-label mb-6">Writing</div>
      <h1 class="text-[clamp(40px,6vw,80px)] font-extrabold tracking-[-0.04em] leading-none">Blogs</h1>
      <p class="mt-5 text-white/45 max-w-md">Approachable writing on AI, engineering, and quantitative finance.</p>
      <input id="blog-search" type="search" placeholder="Search articles…"
        class="mt-9 w-full max-w-lg px-5 py-3.5 rounded-lg bg-carbon border border-white/10 text-sm placeholder:text-white/25 focus:border-neon/40 focus:outline-none" />
      <div class="mt-5 flex flex-wrap gap-2">
        <button data-cat="" class="cat-btn px-4 py-1.5 rounded-full text-xs font-medium border border-violet/50 text-violet">All</button>
        {categories.map((c) => (
          <button data-cat={c} class="cat-btn px-4 py-1.5 rounded-full text-xs font-medium border border-white/10 text-white/50 hover:text-white/80">{c}</button>
        ))}
      </div>
    </div>
  </section>

  <section class="px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-4" id="blog-list">
      {posts.map((p) => (
        <a href={`/blog/${p.id}/`} class="card p-8 block blog-item" data-cat={p.data.category} data-text={`${p.data.title} ${p.data.description}`.toLowerCase()}>
          <span class="text-[10px] uppercase tracking-[0.15em] text-violet font-semibold">{p.data.category}</span>
          <h2 class="mt-3 text-xl font-semibold text-white/90 leading-snug">{p.data.title}</h2>
          <p class="mt-3 text-sm text-white/40 leading-relaxed">{p.data.description}</p>
          <div class="mt-5 flex items-center gap-3 text-[12px] text-white/30">
            <span class="text-white/50 font-medium">{p.data.author}</span>
            <span>{p.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            {p.data.readingTime && <span class="ml-auto">{p.data.readingTime}</span>}
          </div>
        </a>
      ))}
    </div>
  </section>

  <script>
    const input = document.getElementById('blog-search');
    const items = [...document.querySelectorAll('.blog-item')];
    const btns = [...document.querySelectorAll('.cat-btn')];
    let cat = '';
    function apply() {
      const q = input.value.trim().toLowerCase();
      items.forEach((el) => {
        const ok = (!cat || el.dataset.cat === cat) && (!q || el.dataset.text.includes(q));
        el.style.display = ok ? '' : 'none';
      });
    }
    input?.addEventListener('input', apply);
    btns.forEach((b) => b.addEventListener('click', () => {
      cat = b.dataset.cat;
      btns.forEach((x) => x.className = x.className.replace('border-violet/50 text-violet', 'border-white/10 text-white/50'));
      b.className = b.className.replace('border-white/10 text-white/50', 'border-violet/50 text-violet');
      apply();
    }));
  </script>
</Base>
