---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => +b.data.date - +a.data.date);
const categories = [...new Set(posts.map(p => p.data.category))];
const searchIndex = posts.map(p => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description,
  author: p.data.author,
  category: p.data.category,
}));
const catColor = (c) => ({
  'AI': 'var(--accent)',
  'Research': 'var(--cyan)',
  'Engineering': 'var(--green)',
  'Quantitative Finance': 'var(--gold)',
  'Opinion': 'var(--accent2)',
  'Tutorials': 'var(--accent2)',
}[c] || 'var(--accent)');
---
<Base title="Blog — QuantHQ">
  <section class="px-8 pt-20 pb-8">
    <div class="max-w-[var(--shell)] mx-auto">
      <div class="section-label mb-6">Writing</div>
      <h1 class="text-[clamp(56px,9vw,120px)] display-title leading-none">Blogs</h1>
      <p class="mt-5 text-[var(--text-2)] max-w-md">Approachable writing on AI, engineering, and quantitative finance.</p>
      <input id="blog-search" type="search" placeholder="Search articles…"
        class="mt-9 w-full max-w-lg px-5 py-3.5 rounded-lg bg-[var(--card-bg)] border border-[var(--border)] text-sm text-[var(--text)] placeholder:text-[var(--text-3)] focus:border-accent-40 focus:outline-none" />
      <div class="mt-5 flex flex-wrap gap-2">
        <button data-cat="" class="cat-btn px-4 py-1.5 rounded-full text-xs font-medium border border-accent2-50 text-[var(--accent2)]">All</button>
        {categories.map((c) => (
          <button data-cat={c} class="cat-btn px-4 py-1.5 rounded-full text-xs font-medium border border-[var(--border)] text-[var(--text-2)] hover:text-[var(--text-1)]">{c}</button>
        ))}
      </div>
    </div>
  </section>

  <section class="px-8">
    <div class="max-w-[var(--shell)] mx-auto">
      <p id="blog-empty" class="hidden text-[var(--text-2)] text-sm py-8">No posts match that search.</p>
    </div>
    <div class="max-w-[var(--shell)] mx-auto grid md:grid-cols-2 gap-4" id="blog-list">
      {posts.map((p) => {
        const col = catColor(p.data.category);
        return (
        <a href={`/blog/${p.id}/`} class="card p-8 block blog-item group overflow-hidden relative" data-id={p.id} data-cat={p.data.category} style={`--glow: color-mix(in srgb, ${col} 22%, transparent)`}>
          <div class="absolute top-0 left-0 right-0 h-[3px]" style={`background: linear-gradient(90deg, ${col}, transparent 78%)`}></div>
          <div class="absolute top-0 right-0 w-44 h-44 pointer-events-none" style={`background: radial-gradient(circle at 100% 0%, ${col}, transparent 68%); opacity: 0.09`}></div>
          <span class="relative text-[10px] uppercase tracking-[0.15em] font-semibold" style={`color: ${col}`}>{p.data.category}</span>
          <h2 class="relative font-semibold text-[var(--text-1)] leading-snug group-hover:text-[var(--text)] transition-colors mt-3 text-xl">{p.data.title}</h2>
          <p class="relative mt-3 text-sm text-[var(--text-2)] leading-relaxed">{p.data.description}</p>
          <div class="relative mt-6 flex items-center gap-3 text-[12px] text-[var(--text-3)]">
            <span class="text-[var(--text-2)] font-medium">{p.data.author}</span>
            <span class="font-mono">{p.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            {p.data.readingTime && <span class="ml-auto font-mono">{p.data.readingTime}</span>}
          </div>
        </a>
        );
      })}
    </div>
  </section>

  <script define:vars={{ searchIndex }} data-astro-rerun>
    (function () {
    const input = document.getElementById('blog-search');
    const items = [...document.querySelectorAll('.blog-item')];
    const btns = [...document.querySelectorAll('.cat-btn')];
    let cat = '';
    // 2 posts — see research/index.astro: local substring match, no CDN dependency
    const haystack = new Map(searchIndex.map((p) => [p.id,
      [p.title, p.description, p.author, p.category].join(' ').toLowerCase()]));

    function apply() {
      const q = input.value.trim().toLowerCase();
      const matched = q
        ? new Set([...haystack].filter(([, t]) => t.includes(q)).map(([id]) => id))
        : null;
      let shown = 0;
      items.forEach((el) => {
        const catOk = !cat || el.dataset.cat === cat;
        const qOk = !matched || matched.has(el.dataset.id);
        const on = catOk && qOk;
        if (on) shown++;
        el.style.display = on ? '' : 'none';
      });
      document.getElementById('blog-empty').classList.toggle('hidden', shown > 0);
    }

    input?.addEventListener('input', apply);
    btns.forEach((b) => b.addEventListener('click', () => {
      cat = b.dataset.cat;
      btns.forEach((x) => {
        x.style.borderColor = '';
        x.style.color = '';
      });
      b.style.borderColor = 'var(--accent2)';
      b.style.color = 'var(--accent2)';
      apply();
    }));
    })();
  </script>
</Base>
