---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const papers = (await getCollection('research')).sort((a, b) => +b.data.date - +a.data.date);
const featured = papers.find((p) => p.data.featured);
const rest = papers.filter((p) => p !== featured);
const allTags = [...new Set(papers.flatMap((p) => p.data.tags))];
const searchIndex = papers.map((p) => ({
  id: p.id,
  title: p.data.title,
  abstract: p.data.abstract,
  authors: p.data.authors.join(' '),
  tags: p.data.tags,
}));
---
<Base title="Research — QuantHQ">
  <section class="px-6 pt-20 pb-8">
    <div class="max-w-6xl mx-auto">
      <div class="section-label mb-6">Scientific Archive</div>
      <h1 class="text-[clamp(40px,6vw,80px)] font-extrabold tracking-[-0.04em] leading-none">Research</h1>
      <p class="mt-5 text-[var(--text-2)] max-w-md">Peer-reviewed work. Preprints. Technical reports.</p>

      <input
        id="paper-search"
        type="search"
        placeholder="Search papers, authors, topics…"
        class="mt-9 w-full max-w-lg px-5 py-3.5 rounded-lg bg-[var(--card-bg)] border border-[var(--border)] text-sm text-[var(--text)] placeholder:text-[var(--text-3)] focus:border-accent-40 focus:outline-none"
      />
      <div class="mt-5 flex flex-wrap gap-2" id="tag-filters">
        <button data-tag="" class="tag-btn px-4 py-1.5 rounded-full text-xs font-medium border border-accent-40 text-[var(--accent)]">All</button>
        {allTags.map((t) => (
          <button data-tag={t} class="tag-btn px-4 py-1.5 rounded-full text-xs font-medium border border-[var(--border)] text-[var(--text-2)] hover:text-[var(--text-1)]">{t}</button>
        ))}
      </div>
    </div>
  </section>

  {featured && (
    <section class="px-6 pb-8">
      <div class="max-w-6xl mx-auto">
        <a href={`/research/${featured.id}/`} class="card p-8 block group rv relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[var(--accent)] to-[var(--accent2)]"></div>
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="text-[9px] uppercase tracking-[0.2em] px-2.5 py-1 rounded-full bg-accent-10 border border-accent-20 text-[var(--accent)] font-semibold">Featured</span>
            {featured.data.tags.map((t) => (
              <span class="text-[9px] uppercase tracking-[0.2em] px-2.5 py-1 rounded-full border border-accent-20 text-[var(--accent)] font-semibold">{t}</span>
            ))}
            <span class="text-[10px] uppercase tracking-[0.15em] text-[var(--text-3)] ml-auto">{featured.data.status}{featured.data.conference ? ` · ${featured.data.conference}` : ''}</span>
          </div>
          <h2 class="text-2xl font-semibold text-[var(--text)] leading-snug group-hover:text-[var(--accent)] transition-colors">{featured.data.title}</h2>
          <p class="mt-3 text-sm text-[var(--text-2)] leading-relaxed max-w-3xl">{featured.data.abstract}</p>
          <div class="mt-5 flex items-center gap-4 text-[12px] text-[var(--text-3)]">
            <span class="text-[var(--text-2)] font-medium">{featured.data.authors.join(' · ')}</span>
            <span>{featured.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
            <span class="ml-auto text-[var(--accent)] font-semibold uppercase text-[11px] tracking-wide group-hover:tracking-wider transition-all">Read paper →</span>
          </div>
        </a>
      </div>
    </section>
  )}

  <section class="px-6">
    <div class="max-w-6xl mx-auto flex flex-col gap-4" id="paper-list">
      {rest.map((p) => (
        <a href={`/research/${p.id}/`} class="card p-8 block paper-item group" data-id={p.id} data-tags={p.data.tags.join(',')}>
          <div class="flex flex-wrap items-center gap-2 mb-4">
            {p.data.tags.map((t) => (
              <span class="text-[9px] uppercase tracking-[0.2em] px-2.5 py-1 rounded-full border border-accent-20 text-[var(--accent)] font-semibold">{t}</span>
            ))}
            <span class="text-[10px] uppercase tracking-[0.15em] text-[var(--text-3)] ml-auto">{p.data.status}{p.data.conference ? ` · ${p.data.conference}` : ''}</span>
          </div>
          <h2 class="text-xl font-semibold text-[var(--text-1)] leading-snug group-hover:text-[var(--text)] transition-colors">{p.data.title}</h2>
          <p class="mt-3 text-sm text-[var(--text-2)] leading-relaxed line-clamp-3 max-w-3xl">{p.data.abstract}</p>
          <div class="mt-5 flex items-center gap-4 text-[12px] text-[var(--text-3)]">
            <span class="text-[var(--text-2)] font-medium">{p.data.authors.join(' · ')}</span>
            <span>{p.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
            <span class="ml-auto text-[var(--accent)] font-semibold uppercase text-[11px] tracking-wide group-hover:tracking-wider transition-all">Read paper →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <script define:vars={{ searchIndex }} data-astro-rerun>
    (function () {
    const items = [...document.querySelectorAll('.paper-item')];
    const tagBtns = [...document.querySelectorAll('.tag-btn')];
    let activeTag = '';
    let fuse = null;

    function apply() {
      const input = document.getElementById('paper-search');
      const q = input.value.trim();
      const matched = (q && fuse) ? new Set(fuse.search(q).map((r) => r.item.id)) : null;
      items.forEach((el) => {
        const tagOk = !activeTag || el.dataset.tags.split(',').includes(activeTag);
        const qOk = !matched || matched.has(el.dataset.id);
        el.style.display = tagOk && qOk ? '' : 'none';
      });
    }

    document.getElementById('paper-search')?.addEventListener('input', apply);
    tagBtns.forEach((b) => b.addEventListener('click', () => {
      activeTag = b.dataset.tag;
      tagBtns.forEach((x) => { x.style.borderColor = ''; x.style.color = ''; });
      b.style.borderColor = 'var(--accent)';
      b.style.color = 'var(--accent)';
      apply();
    }));

    import('https://cdn.jsdelivr.net/npm/fuse.js@7/dist/fuse.mjs').then(({ default: Fuse }) => {
      fuse = new Fuse(searchIndex, { keys: ['title', 'abstract', 'authors', 'tags'], threshold: 0.35 });
    });
    })();
  </script>
</Base>
