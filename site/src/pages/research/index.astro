---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const papers = (await getCollection('research')).sort((a, b) => +b.data.date - +a.data.date);
const allTags = [...new Set(papers.flatMap((p) => p.data.tags))];
const searchIndex = papers.map((p) => ({
  id: p.id,
  title: p.data.title,
  abstract: p.data.abstract,
  authors: p.data.authors.join(' '),
  tags: p.data.tags,
}));
---
<Base title="Research — QuantHQ">
  <section class="px-6 pt-20 pb-8">
    <div class="max-w-6xl mx-auto">
      <div class="section-label mb-6">Scientific Archive</div>
      <h1 class="text-[clamp(40px,6vw,80px)] font-extrabold tracking-[-0.04em] leading-none">Research</h1>
      <p class="mt-5 text-white/45 max-w-md">Peer-reviewed work. Preprints. Technical reports.</p>

      <input
        id="paper-search"
        type="search"
        placeholder="Search papers, authors, topics…"
        class="mt-9 w-full max-w-lg px-5 py-3.5 rounded-lg bg-carbon border border-white/10 text-sm placeholder:text-white/25 focus:border-neon/40 focus:outline-none"
      />
      <div class="mt-5 flex flex-wrap gap-2" id="tag-filters">
        <button data-tag="" class="tag-btn px-4 py-1.5 rounded-full text-xs font-medium border border-neon/40 text-neon">All</button>
        {allTags.map((t) => (
          <button data-tag={t} class="tag-btn px-4 py-1.5 rounded-full text-xs font-medium border border-white/10 text-white/50 hover:text-white/80">{t}</button>
        ))}
      </div>
    </div>
  </section>

  <section class="px-6">
    <div class="max-w-6xl mx-auto flex flex-col gap-4" id="paper-list">
      {papers.map((p) => (
        <a href={`/research/${p.id}/`} class="card p-8 block paper-item" data-id={p.id} data-tags={p.data.tags.join(',')}>
          <div class="flex flex-wrap items-center gap-2 mb-4">
            {p.data.tags.map((t) => (
              <span class="text-[9px] uppercase tracking-[0.2em] px-2.5 py-1 rounded-full border border-neon/20 text-neon font-semibold">{t}</span>
            ))}
            <span class="text-[10px] uppercase tracking-[0.15em] text-white/25 ml-auto">{p.data.status}{p.data.conference ? ` · ${p.data.conference}` : ''}</span>
          </div>
          <h2 class="text-xl font-semibold text-white/90 leading-snug">{p.data.title}</h2>
          <p class="mt-3 text-sm text-white/40 leading-relaxed line-clamp-3 max-w-3xl">{p.data.abstract}</p>
          <div class="mt-5 flex items-center gap-4 text-[12px] text-white/30">
            <span class="text-white/50 font-medium">{p.data.authors.join(' · ')}</span>
            <span>{p.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
            <span class="ml-auto text-neon font-semibold uppercase text-[11px] tracking-wide">Read paper →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <script define:vars={{ searchIndex }}>
    import('https://cdn.jsdelivr.net/npm/fuse.js@7/dist/fuse.mjs').then(({ default: Fuse }) => {
      const fuse = new Fuse(searchIndex, { keys: ['title', 'abstract', 'authors', 'tags'], threshold: 0.35 });
      const input = document.getElementById('paper-search');
      const items = [...document.querySelectorAll('.paper-item')];
      const tagBtns = [...document.querySelectorAll('.tag-btn')];
      let activeTag = '';

      function apply() {
        const q = input.value.trim();
        const matched = q ? new Set(fuse.search(q).map((r) => r.item.id)) : null;
        items.forEach((el) => {
          const tagOk = !activeTag || el.dataset.tags.split(',').includes(activeTag);
          const qOk = !matched || matched.has(el.dataset.id);
          el.style.display = tagOk && qOk ? '' : 'none';
        });
      }
      input.addEventListener('input', apply);
      tagBtns.forEach((b) => b.addEventListener('click', () => {
        activeTag = b.dataset.tag;
        tagBtns.forEach((x) => x.className = x.className.replace('border-neon/40 text-neon', 'border-white/10 text-white/50'));
        b.className = b.className.replace('border-white/10 text-white/50', 'border-neon/40 text-neon');
        apply();
      }));
    });
  </script>
</Base>
