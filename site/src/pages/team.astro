---
import Base from '../layouts/Base.astro';
const team = [
  ['Shubh Jain', 'Founder', 'Quant research · AI systems'],
  ['Open Role', 'Research Lead', 'Factor research · ML'],
  ['Open Role', 'Engineering', 'Infrastructure · Tooling'],
];
---
<Base title="Team — QuantHQ">
  <section class="px-6 pt-20">
    <div class="max-w-6xl mx-auto">
      <div class="section-label mb-6">People</div>
      <h1 class="text-[clamp(40px,6vw,80px)] font-extrabold tracking-[-0.04em] leading-none">Team</h1>
      <div class="mt-14 grid sm:grid-cols-2 md:grid-cols-3 gap-4">
        {team.map(([name, role, focus]) => (
          <div class="card p-8 rv">
            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-neon to-violet flex items-center justify-center font-bold text-black text-lg">
              {name.split(' ').map((w) => w[0]).join('')}
            </div>
            <h2 class="mt-5 font-semibold text-white/90">{name}</h2>
            <div class="text-[12px] text-neon mt-1">{role}</div>
            <p class="mt-2 text-[13px] text-white/35">{focus}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
