---
import Base from '../layouts/Base.astro';
const socials = [
  {
    label: 'LinkedIn', sub: 'Follow QuantHQ', href: 'https://linkedin.com/company/quanthq', color: 'var(--accent)',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>',
  },
  {
    label: 'Discord', sub: 'Join the community', href: 'https://discord.gg/quanthq', color: 'var(--accent2)',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.36-.495.68-1.02.953-1.572a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>',
  },
  {
    label: 'GitHub', sub: 'Open source', href: 'https://github.com/quanthq', color: 'var(--text-2)',
    icon: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>',
  },
];
---
<Base title="Contact — QuantHQ">
  <section class="px-8 pt-20 pb-8">
    <div class="max-w-3xl mx-auto">
      <div class="section-label mb-6">Contact</div>
      <h1 class="text-[clamp(52px,8vw,104px)] display-title leading-none">Get in touch.</h1>
      <p class="mt-5 text-[var(--text-2)] text-[17px] max-w-lg">Research collaborations, speaking, or joining the network — reach out and we'll get back to you.</p>
    </div>
  </section>

  <section class="px-8">
    <div class="max-w-3xl mx-auto">
      <!-- primary: email -->
      <a href="mailto:hello@quanthq.in" class="card p-8 block group rv relative overflow-hidden" style="--glow: color-mix(in srgb, var(--gold) 20%, transparent)">
        <div class="absolute inset-y-0 left-0 w-[3px] bg-gradient-to-b from-[var(--gold)] to-transparent"></div>
        <div class="flex items-center gap-5">
          <div class="w-12 h-12 rounded-xl bg-[var(--surface-2)] flex items-center justify-center text-[var(--gold)] shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--text-3)]">Primary</div>
            <div class="font-mono text-[clamp(18px,2.6vw,26px)] text-[var(--text-1)] mt-1.5 truncate">hello@quanthq.in</div>
          </div>
          <span class="text-[var(--gold)] text-xl font-semibold opacity-70 group-hover:opacity-100 group-hover:translate-x-1 transition-all shrink-0">→</span>
        </div>
        <div class="mt-6 pt-5 border-t border-[var(--border)] font-mono text-[11px] tracking-[0.04em] text-[var(--text-3)]">
          ↳ Typical reply within 1–2 days · research · speaking · partnerships
        </div>
      </a>

      <!-- secondary: socials -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mt-3">
        {socials.map((s) => (
          <a href={s.href} target="_blank" rel="noopener" class="card p-6 flex sm:flex-col items-center sm:items-start gap-4 sm:gap-5 group rv" style={`--glow: color-mix(in srgb, ${s.color} 20%, transparent)`}>
            <div class="w-11 h-11 rounded-xl bg-[var(--surface-2)] flex items-center justify-center shrink-0" style={`color: ${s.color}`} set:html={s.icon} />
            <div class="flex-1 sm:flex-none">
              <div class="text-[var(--text-1)] font-medium group-hover:text-[var(--text)] transition-colors">{s.label}</div>
              <div class="text-[var(--text-3)] text-[13px] mt-0.5">{s.sub}</div>
            </div>
            <span class="sm:hidden text-[var(--text-3)] group-hover:text-[var(--text-1)] transition-colors ml-auto">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
