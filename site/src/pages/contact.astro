---
import Base from '../layouts/Base.astro';
---
<Base title="Contact — QuantHQ">
  <section class="px-6 pt-20">
    <div class="max-w-2xl mx-auto">
      <div class="section-label mb-6">Contact</div>
      <h1 class="text-[clamp(40px,6vw,72px)] font-extrabold tracking-[-0.04em] leading-none">Get in touch.</h1>
      <p class="mt-5 text-white/45">Research collaborations, speaking, or joining the network.</p>
      <div class="mt-12 flex flex-col gap-4">
        <a href="mailto:hello@quanthq.in" class="card p-6 flex items-center justify-between">
          <span class="text-white/80 font-medium">Email</span>
          <span class="text-neon text-sm">hello@quanthq.in →</span>
        </a>
        <a href="#" class="card p-6 flex items-center justify-between">
          <span class="text-white/80 font-medium">LinkedIn</span>
          <span class="text-neon text-sm">QuantHQ →</span>
        </a>
        <a href="#" class="card p-6 flex items-center justify-between">
          <span class="text-white/80 font-medium">Discord</span>
          <span class="text-neon text-sm">Join the server →</span>
        </a>
      </div>
    </div>
  </section>
</Base>
