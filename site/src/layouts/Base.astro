---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import CommandPalette from '../components/CommandPalette.astro';
const { title = 'QuantHQ', description = 'QuantHQ is a digital research institution building the future of quantitative finance and AI.' } = Astro.props;
const tickers = [
  { sym: 'NVDA', px: '131.42', chg: '+2.8%', dir: 'up' },
  { sym: 'AAPL', px: '212.18', chg: '+1.4%', dir: 'up' },
  { sym: 'MSFT', px: '448.62', chg: '+0.4%', dir: 'up' },
  { sym: 'META', px: '562.90', chg: '+1.9%', dir: 'up' },
  { sym: 'TSLA', px: '189.34', chg: '-1.6%', dir: 'down' },
  { sym: 'BTC', px: '68,420', chg: '+3.1%', dir: 'up' },
  { sym: 'ETH', px: '3,840', chg: '+2.2%', dir: 'up' },
  { sym: 'VIX', px: '16.3', chg: '-2.1%', dir: 'down' },
];
const tapeList = [...tickers, ...tickers];
const nav = [
  { href: '/research/', label: 'Research' },
  { href: '/blog/', label: 'Blogs' },
  { href: '/community/', label: 'Community' },
  { href: '/contact/', label: 'Contact' },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site ?? 'https://quanthq.in')} />
  <meta property="og:image" content="https://quanthq.in/og.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:image" content="https://quanthq.in/og.png" />
  <link rel="icon" id="favicon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 34 34'%3E%3Crect x='3' y='3' width='22' height='22' rx='3' fill='none' stroke='white' stroke-width='2.2'/%3E%3Ctext x='7.5' y='19.5' font-family='sans-serif' font-weight='800' font-size='10.5' fill='white'%3EHQ%3C/text%3E%3Crect x='22' y='22' width='9' height='9' rx='2' fill='white'/%3E%3C/svg%3E" />
  <script is:inline>if(localStorage.theme==='light')document.documentElement.classList.add('light')</script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <ClientRouter />
</head>
<body class="min-h-screen antialiased">
  <div aria-hidden="true">
    <div class="bgfx-blob bgfx-b1"></div>
    <div class="bgfx-blob bgfx-b2"></div>
    <div class="bgfx-aurora"></div>
    <div class="bgfx-grid"></div>
    <div class="vignette-fx"></div>
    <div class="bgfx-grain"></div>
  </div>
  <div class="tape" aria-hidden="true">
    <div class="tape-track">
      {tapeList.map((t) => (
        <span><span class="tape-sym">{t.sym}</span><span class="tape-px">{t.px}</span><span class={`tape-chg ${t.dir}`}>{t.chg}</span></span>
      ))}
    </div>
  </div>
  <nav class="lg-nav">
    <div class="max-w-[var(--shell)] mx-auto px-8 h-full flex items-center gap-12 w-full">
      <a href="/" class="flex items-center gap-2.5 font-bold text-[15px] tracking-tight">
        <svg width="26" height="26" viewBox="0 0 34 34" fill="none" aria-hidden="true" class="shrink-0">
          <rect x="3" y="3" width="22" height="22" rx="3" stroke="currentColor" stroke-width="2.2" fill="none"/>
          <text x="7.5" y="19.5" font-family="Inter,system-ui,sans-serif" font-weight="800" font-size="10.5" fill="currentColor">HQ</text>
          <rect x="22" y="22" width="9" height="9" rx="2" fill="var(--accent)"/>
        </svg>
        QuantHQ
      </a>
      <div class="hidden md:flex items-center gap-8 ml-auto text-[13px] font-medium">
        <a href="/about/" class="text-[var(--text-2)] hover:text-[var(--text-1)] transition-colors">About</a>
        {nav.map((n) => (
          <a href={n.href} class="text-[var(--text-2)] hover:text-[var(--text-1)] transition-colors">{n.label}</a>
        ))}
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle light mode">
          <svg class="tt-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
          <svg class="tt-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <a href="/#join" class="nav-cta">Join →</a>
      </div>
      <button id="mnav-btn" class="md:hidden ml-auto p-2" aria-label="Toggle menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
      </button>
    </div>
    <div id="mnav" class="hidden md:hidden bg-ink-97 backdrop-blur-xl border-b border-[var(--border)] px-8 py-4 flex-col gap-3 text-[15px]">
      <a href="/about/" class="block py-2 text-[var(--text-1)]">About</a>
      {nav.map((n) => <a href={n.href} class="block py-2 text-[var(--text-1)]">{n.label}</a>)}
    </div>
  </nav>

  <main class="pt-16 md:pt-[92px]">
    <slot />
  </main>

  <footer class="border-t border-[var(--border)] mt-32 py-14 px-8">
    <div class="max-w-[var(--shell)] mx-auto flex flex-wrap justify-between gap-10">
      <div>
        <div class="font-display text-[26px] leading-none mb-3">QuantHQ</div>
        <p class="text-[var(--text-3)] text-sm max-w-56">A digital research institution for quantitative finance and AI.</p>
        <div class="flex gap-3 mt-5">
          <a href="https://discord.gg/quanthq" target="_blank" rel="noopener" class="w-8 h-8 rounded-full bg-[var(--surface-2)] flex items-center justify-center text-[var(--text-3)] hover:text-[var(--accent)] hover:bg-[var(--border-hover)] transition-colors" aria-label="Discord">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
          </a>
          <a href="https://github.com/quanthq" target="_blank" rel="noopener" class="w-8 h-8 rounded-full bg-[var(--surface-2)] flex items-center justify-center text-[var(--text-3)] hover:text-[var(--accent)] hover:bg-[var(--border-hover)] transition-colors" aria-label="GitHub">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://linkedin.com/company/quanthq" target="_blank" rel="noopener" class="w-8 h-8 rounded-full bg-[var(--surface-2)] flex items-center justify-center text-[var(--text-3)] hover:text-[var(--accent)] hover:bg-[var(--border-hover)] transition-colors" aria-label="LinkedIn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
      <div class="flex gap-16 text-sm">
        <div class="flex flex-col gap-2.5">
          <span class="text-[10px] uppercase tracking-[0.2em] text-[var(--text-3)] font-semibold mb-1">Explore</span>
          <a href="/research/" class="text-[var(--text-2)] hover:text-[var(--text-1)]">Research</a>
          <a href="/blog/" class="text-[var(--text-2)] hover:text-[var(--text-1)]">Blogs</a>
        </div>
        <div class="flex flex-col gap-2.5">
          <span class="text-[10px] uppercase tracking-[0.2em] text-[var(--text-3)] font-semibold mb-1">Org</span>
          <a href="/about/" class="text-[var(--text-2)] hover:text-[var(--text-1)]">About</a>
          <a href="/contact/" class="text-[var(--text-2)] hover:text-[var(--text-1)]">Contact</a>
        </div>
      </div>
    </div>
    <div class="max-w-[var(--shell)] mx-auto mt-10 pt-6 border-t border-[var(--border)] flex items-center justify-between text-xs text-[var(--text-3)]">
      <span>© 2026 QuantHQ. All rights reserved.</span>
      <button onclick="window.scrollTo({top:0,behavior:'smooth'})" class="hover:text-[var(--text-2)] transition-colors cursor-pointer">Back to top ↑</button>
    </div>
  </footer>

  <CommandPalette />

  <script>
    const FAVICON_DARK="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 34 34'%3E%3Crect x='3' y='3' width='22' height='22' rx='3' fill='none' stroke='white' stroke-width='2.2'/%3E%3Ctext x='7.5' y='19.5' font-family='sans-serif' font-weight='800' font-size='10.5' fill='white'%3EHQ%3C/text%3E%3Crect x='22' y='22' width='9' height='9' rx='2' fill='white'/%3E%3C/svg%3E";
    const FAVICON_LIGHT="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 34 34'%3E%3Crect x='3' y='3' width='22' height='22' rx='3' fill='none' stroke='black' stroke-width='2.2'/%3E%3Ctext x='7.5' y='19.5' font-family='sans-serif' font-weight='800' font-size='10.5' fill='black'%3EHQ%3C/text%3E%3Crect x='22' y='22' width='9' height='9' rx='2' fill='black'/%3E%3C/svg%3E";
    // The ClientRouter swaps the DOM on navigation, so all element bindings
    // re-run on astro:page-load (which also fires on the initial load).
    function initBase() {
      if(document.documentElement.classList.contains('light'))document.getElementById('favicon').href=FAVICON_LIGHT;
      document.querySelector('.bgfx-grain')?.classList.add('active');

      document.getElementById('mnav-btn')?.addEventListener('click', () => {
        document.getElementById('mnav')?.classList.toggle('hidden');
      });
      document.querySelectorAll('#mnav a').forEach(a => a.addEventListener('click', () => {
        document.getElementById('mnav')?.classList.add('hidden');
      }));

      const io = new IntersectionObserver((es) => es.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      }), { threshold: 0.12 });
      document.querySelectorAll('.rv').forEach((el) => io.observe(el));
      document.querySelectorAll('.card').forEach((c) => c.addEventListener('mousemove', (e) => {
        const r = c.getBoundingClientRect();
        c.style.setProperty('--mx', (e.clientX - r.left) + 'px');
        c.style.setProperty('--my', (e.clientY - r.top) + 'px');
      }, { passive: true }));
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const light = document.documentElement.classList.toggle('light');
        localStorage.theme = light ? 'light' : 'dark';
        document.getElementById('favicon').href = light ? FAVICON_LIGHT : FAVICON_DARK;
      });
    }
    document.addEventListener('astro:page-load', initBase);
    // the swap replaces <html>, so re-apply the persisted theme class
    document.addEventListener('astro:after-swap', () => {
      if (localStorage.theme === 'light') document.documentElement.classList.add('light');
    });
  </script>
</body>
</html>
