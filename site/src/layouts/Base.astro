---
import '../styles/global.css';
const { title = 'QuantHQ', description = 'QuantHQ is a digital research institution building the future of quantitative finance and AI.' } = Astro.props;
const nav = [
  { href: '/research/', label: 'Research' },
  { href: '/blog/', label: 'Blogs' },
  { href: '/projects/', label: 'Projects' },
  { href: '/community/', label: 'Community' },
  { href: '/team/', label: 'Team' },
  { href: '/contact/', label: 'Contact' },
];
const aboutTabs = ['Mission', 'Research', 'Build', 'Community', 'Education', 'Future'];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen antialiased">
  <nav class="fixed top-0 inset-x-0 z-50 h-16 border-b border-white/5 bg-ink/85 backdrop-blur-xl">
    <div class="max-w-6xl mx-auto px-6 h-full flex items-center gap-10">
      <a href="/" class="flex items-center gap-2.5 font-bold text-[15px] tracking-tight">
        <svg width="26" height="26" viewBox="0 0 34 34" fill="none" aria-hidden="true" class="shrink-0">
          <rect x="3" y="3" width="22" height="22" rx="3" stroke="currentColor" stroke-width="2.2" fill="none"/>
          <text x="7.5" y="19.5" font-family="Inter,system-ui,sans-serif" font-weight="800" font-size="10.5" fill="currentColor">HQ</text>
          <rect x="22" y="22" width="9" height="9" rx="2" fill="#FFFFFF"/>
        </svg>
        QuantHQ
      </a>
      <div class="hidden md:flex items-center gap-7 ml-auto text-[13px] font-medium">
        <div class="relative group">
          <a href="/about/" class="text-white/55 hover:text-white/90 transition-colors">About ▾</a>
          <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 hidden group-hover:block">
            <div class="bg-carbon border border-white/10 rounded-lg py-2 w-40 shadow-2xl">
              {aboutTabs.map((t) => (
                <a href={`/about/#${t.toLowerCase()}`} class="block px-4 py-1.5 text-white/55 hover:text-white hover:bg-white/5">{t}</a>
              ))}
            </div>
          </div>
        </div>
        {nav.map((n) => (
          <a href={n.href} class="text-white/55 hover:text-white/90 transition-colors">{n.label}</a>
        ))}
      </div>
      <button id="mnav-btn" class="md:hidden ml-auto p-2" aria-label="Toggle menu">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
      </button>
    </div>
    <div id="mnav" class="hidden md:hidden bg-ink/97 backdrop-blur-xl border-b border-white/10 px-6 py-4 flex-col gap-3 text-[15px]">
      <a href="/about/" class="block py-2 text-white/70">About</a>
      {nav.map((n) => <a href={n.href} class="block py-2 text-white/70">{n.label}</a>)}
    </div>
  </nav>

  <main class="pt-16">
    <slot />
  </main>

  <footer class="border-t border-white/5 mt-32 py-14 px-6">
    <div class="max-w-6xl mx-auto flex flex-wrap justify-between gap-10">
      <div>
        <div class="font-bold text-lg mb-2">QuantHQ</div>
        <p class="text-white/35 text-sm max-w-56">A digital research institution for quantitative finance and AI.</p>
      </div>
      <div class="flex gap-16 text-sm">
        <div class="flex flex-col gap-2.5">
          <span class="text-[10px] uppercase tracking-[0.2em] text-white/25 font-semibold mb-1">Explore</span>
          <a href="/research/" class="text-white/45 hover:text-white/80">Research</a>
          <a href="/blog/" class="text-white/45 hover:text-white/80">Blogs</a>
          <a href="/projects/" class="text-white/45 hover:text-white/80">Projects</a>
        </div>
        <div class="flex flex-col gap-2.5">
          <span class="text-[10px] uppercase tracking-[0.2em] text-white/25 font-semibold mb-1">Org</span>
          <a href="/about/" class="text-white/45 hover:text-white/80">About</a>
          <a href="/team/" class="text-white/45 hover:text-white/80">Team</a>
          <a href="/contact/" class="text-white/45 hover:text-white/80">Contact</a>
        </div>
      </div>
    </div>
    <div class="max-w-6xl mx-auto mt-10 pt-6 border-t border-white/5 text-xs text-white/20">© 2026 QuantHQ. All rights reserved.</div>
  </footer>

  <script>
    document.getElementById('mnav-btn')?.addEventListener('click', () => {
      document.getElementById('mnav')?.classList.toggle('hidden');
    });
    const io = new IntersectionObserver((es) => es.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    }), { threshold: 0.12 });
    document.querySelectorAll('.rv').forEach((el) => io.observe(el));
  </script>
</body>
</html>
