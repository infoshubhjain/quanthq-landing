---
// Site-wide ⌘K command palette. Included in both the standalone homepage and
// Base.astro. Navigation-first so every command works from any page.
const commands = [
  { label: 'Research',            hint: 'Papers & preprints',      href: '/research/',  group: 'Navigate' },
  { label: 'Blog',                hint: 'Writing & essays',        href: '/blog/',      group: 'Navigate' },
  { label: 'About',               hint: 'Mission & team',          href: '/about/',     group: 'Navigate' },
  { label: 'Community',           hint: 'Discord, hackathons',     href: '/community/', group: 'Navigate' },
  { label: 'Contact',             hint: 'Get in touch',            href: '/contact/',   group: 'Navigate' },
  { label: 'Home',                hint: 'Back to the landing',     href: '/',           group: 'Navigate' },
  { label: 'Intelligence Layer',  hint: 'Live quant dashboard',    href: '/#dashboard', group: 'Jump to' },
  { label: 'Global Network',      hint: 'Interactive globe',       href: '/#network',   group: 'Jump to' },
  { label: 'Research Terminal',   hint: 'Try the pipeline',        href: '/#terminal',  group: 'Jump to' },
  { label: 'Early Access',        hint: 'Join the institution',    href: '/#join',      group: 'Jump to' },
  { label: 'Toggle Theme',        hint: 'Light / dark',            action: 'theme',     group: 'Actions' },
  { label: 'GitHub',              hint: 'Open source',             href: 'https://github.com/quanthq',            ext: true, group: 'External' },
  { label: 'Discord',             hint: 'Join the chat',           href: 'https://discord.gg/quanthq',            ext: true, group: 'External' },
  { label: 'LinkedIn',            hint: 'Follow QuantHQ',          href: 'https://linkedin.com/company/quanthq',  ext: true, group: 'External' },
];
---
<button class="cmdk-trigger" id="cmdk-trigger" aria-label="Open command menu (Command K)">
  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
  <kbd>⌘K</kbd>
</button>

<div class="cmdk-overlay" id="cmdk" role="dialog" aria-modal="true" aria-label="Command menu" hidden>
  <div class="cmdk-panel">
    <div class="cmdk-search">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      <input id="cmdk-input" type="text" placeholder="Search or jump to…" autocomplete="off" spellcheck="false" aria-label="Search commands" />
      <kbd class="cmdk-esc">ESC</kbd>
    </div>
    <div class="cmdk-list" id="cmdk-list" role="listbox">
      {commands.map((c) => (
        <button
          class="cmdk-item"
          role="option"
          data-label={c.label}
          data-hint={c.hint}
          data-group={c.group}
          data-href={c.href ?? ''}
          data-action={c.action ?? ''}
          data-ext={c.ext ? '1' : ''}
        >
          <span class="cmdk-item-label">{c.label}</span>
          <span class="cmdk-item-hint">{c.hint}</span>
          <span class="cmdk-item-arrow">↵</span>
        </button>
      ))}
    </div>
    <div class="cmdk-empty" id="cmdk-empty" hidden>No matches</div>
    <div class="cmdk-foot">
      <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
      <span><kbd>↵</kbd> select</span>
      <span class="cmdk-foot-brand">QuantHQ</span>
    </div>
  </div>
</div>

<style>
.cmdk-trigger{
  position:fixed;right:22px;bottom:40px;z-index:700;
  display:inline-flex;align-items:center;gap:8px;
  padding:7px 11px;border-radius:999px;cursor:pointer;
  background:color-mix(in srgb,var(--card-bg,#090D15) 80%,transparent);
  backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
  border:1px solid var(--border);color:var(--text-3);
  transition:color .2s,border-color .2s,transform .2s var(--ease-out,ease);
}
.cmdk-trigger:hover{color:var(--text-1);border-color:var(--border-hover);transform:translateY(-2px)}
.cmdk-trigger kbd{
  font-family:var(--font-mono,monospace);font-size:10px;letter-spacing:.05em;
  color:var(--text-2);background:var(--surface-2);border:1px solid var(--border);
  padding:1px 5px;border-radius:4px;
}
@media(max-width:767px){.cmdk-trigger{bottom:16px;right:16px}.cmdk-trigger kbd{display:none}}

.cmdk-overlay{
  position:fixed;inset:0;z-index:9500;
  display:flex;align-items:flex-start;justify-content:center;
  padding-top:14vh;
  background:color-mix(in srgb,var(--bg,#04060B) 55%,transparent);
  backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);
  opacity:0;transition:opacity .18s ease;
}
.cmdk-overlay.open{opacity:1}
.cmdk-overlay[hidden]{display:none}
.cmdk-panel{
  width:min(92vw,560px);max-height:64vh;display:flex;flex-direction:column;
  background:var(--card-bg,#090D15);
  border:1px solid var(--border-hover);border-radius:14px;
  box-shadow:0 40px 100px -20px rgba(0,0,0,.6),0 0 0 1px var(--border);
  overflow:hidden;
  transform:translateY(-8px) scale(.98);opacity:0;
  transition:transform .2s var(--ease-out,ease),opacity .2s ease;
}
.cmdk-overlay.open .cmdk-panel{transform:none;opacity:1}
.cmdk-search{
  display:flex;align-items:center;gap:10px;padding:15px 16px;
  border-bottom:1px solid var(--border);color:var(--text-3);
}
#cmdk-input{
  flex:1;background:transparent;border:none;outline:none;
  color:var(--text);font-family:var(--font-sans,inherit);font-size:15px;
}
#cmdk-input::placeholder{color:var(--text-3)}
.cmdk-esc{
  font-family:var(--font-mono,monospace);font-size:9px;letter-spacing:.1em;
  color:var(--text-3);border:1px solid var(--border);border-radius:4px;padding:2px 6px;
}
.cmdk-list{overflow-y:auto;padding:8px;scrollbar-width:thin}
.cmdk-item{
  width:100%;display:flex;align-items:center;gap:12px;
  padding:11px 12px;border-radius:9px;cursor:pointer;text-align:left;
  color:var(--text-2);transition:background .12s,color .12s;
}
.cmdk-item[hidden]{display:none}
.cmdk-item.active{background:var(--surface-2);color:var(--text)}
.cmdk-item.active .cmdk-item-arrow{opacity:1;color:var(--gold)}
.cmdk-item-label{font-size:14px;font-weight:500;flex-shrink:0}
.cmdk-item-hint{font-size:12px;color:var(--text-3);margin-left:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cmdk-item-arrow{margin-left:auto;font-size:12px;color:var(--text-3);opacity:0;font-family:var(--font-mono,monospace)}
.cmdk-empty{padding:28px 16px;text-align:center;color:var(--text-3);font-size:13px}
.cmdk-empty[hidden]{display:none}
.cmdk-foot{
  display:flex;align-items:center;gap:16px;
  padding:10px 16px;border-top:1px solid var(--border);
  font-size:11px;color:var(--text-3);font-family:var(--font-mono,monospace);
}
.cmdk-foot kbd{border:1px solid var(--border);border-radius:3px;padding:0 4px;margin-right:2px}
.cmdk-foot-brand{margin-left:auto;letter-spacing:.15em;color:var(--text-4)}

@media(prefers-reduced-motion:reduce){
  .cmdk-overlay,.cmdk-panel,.cmdk-trigger{transition:none}
}
</style>

<script>
  function initCmdK() {
    const overlay = document.getElementById('cmdk');
    if (!overlay || overlay.dataset.bound) return;
    overlay.dataset.bound = '1';

    const input = document.getElementById('cmdk-input');
    const list = document.getElementById('cmdk-list');
    const empty = document.getElementById('cmdk-empty');
    const trigger = document.getElementById('cmdk-trigger');
    const items = () => [...list.querySelectorAll('.cmdk-item')];
    const visible = () => items().filter(i => !i.hidden);
    let active = 0;

    function setActive(i) {
      const vis = visible();
      if (!vis.length) return;
      active = (i + vis.length) % vis.length;
      items().forEach(el => el.classList.remove('active'));
      vis[active].classList.add('active');
      vis[active].scrollIntoView({ block: 'nearest' });
    }
    function filter() {
      const q = input.value.trim().toLowerCase();
      let shown = 0;
      items().forEach(el => {
        const hay = (el.dataset.label + ' ' + el.dataset.hint + ' ' + el.dataset.group).toLowerCase();
        const ok = !q || hay.includes(q);
        el.hidden = !ok; if (ok) shown++;
      });
      empty.hidden = shown > 0;
      active = 0; setActive(0);
    }
    function open() {
      overlay.hidden = false;
      requestAnimationFrame(() => overlay.classList.add('open'));
      input.value = ''; filter(); input.focus();
      document.documentElement.style.overflow = 'hidden';
    }
    function close() {
      overlay.classList.remove('open');
      document.documentElement.style.overflow = '';
      setTimeout(() => { overlay.hidden = true; }, 180);
    }
    function isOpen() { return !overlay.hidden; }
    function run(el) {
      if (!el) return;
      close();
      if (el.dataset.action === 'theme') { document.getElementById('theme-toggle')?.click(); return; }
      const href = el.dataset.href;
      if (!href) return;
      if (el.dataset.ext) window.open(href, '_blank', 'noopener');
      else window.location.href = href;
    }

    input.addEventListener('input', filter);
    list.addEventListener('click', e => { const it = e.target.closest('.cmdk-item'); if (it) run(it); });
    list.addEventListener('pointermove', e => {
      const it = e.target.closest('.cmdk-item'); if (!it || it.hidden) return;
      const vis = visible(); const idx = vis.indexOf(it); if (idx >= 0) setActive(idx);
    });
    input.addEventListener('keydown', e => {
      if (e.key === 'ArrowDown') { e.preventDefault(); setActive(active + 1); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(active - 1); }
      else if (e.key === 'Enter') { e.preventDefault(); run(visible()[active]); }
      else if (e.key === 'Escape') { e.preventDefault(); close(); }
    });
    overlay.addEventListener('click', e => { if (e.target === overlay) close(); });
    trigger?.addEventListener('click', open);

    // expose a toggle for the one persistent global shortcut handler
    window.__cmdkToggle = () => (isOpen() ? close() : open());
    window.__cmdkClose = close;
  }

  // one global shortcut handler, registered once, survives ClientRouter swaps
  if (!window.__cmdkKeys) {
    window.__cmdkKeys = true;
    addEventListener('keydown', e => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') { e.preventDefault(); window.__cmdkToggle?.(); }
      else if (e.key === 'Escape') window.__cmdkClose?.();
    });
  }

  initCmdK();
  document.addEventListener('astro:page-load', initCmdK);
</script>
