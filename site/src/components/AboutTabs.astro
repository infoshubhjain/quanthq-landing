---
const tabs = [
  { id: 'mission', label: 'Mission' },
  { id: 'research', label: 'Research' },
  { id: 'build', label: 'Build' },
  { id: 'community', label: 'Community' },
  { id: 'education', label: 'Education' },
  { id: 'future', label: 'Future' },
];
const data = {
  mission: {
    headline: 'Building practical AI systems through open research.',
    body: 'QuantHQ exists to make rigorous quantitative research open, collaborative, and reproducible.',
    stats: [['18','Research Papers'],['4','Open Source Projects'],['200+','Community Members'],['3','Universities']],
  },
  research: {
    headline: 'A timeline of what we study.',
    body: 'Our research agenda evolves with the frontier.',
    timeline: [['2026',['LLM Evaluation','Financial AI','Agent Systems']],['2027',['Multimodal Market Models','Autonomous Research Agents']]],
  },
  build: {
    headline: 'Research that ships.',
    body: 'Everything we learn becomes something you can run.',
    cards: [['Agent Framework','Open Source'],['Trading Infrastructure','Private'],['Vision Models','Research'],['Cybersecurity','Coming Soon']],
  },
  community: {
    headline: 'Intelligence is a team sport.',
    body: 'Where the network lives.',
    cards: [['Discord','Live'],['Hackathons','Quarterly'],['Reading Groups','Weekly'],['Open Source Contributors','Global'],['Collaborations','Ongoing']],
  },
  education: {
    headline: 'Learn by doing research.',
    body: 'Workshops, courses, mentorship, and summer research programs for the next generation of quants.',
    cards: [['Workshops','Hands-on'],['Courses','Structured'],['Mentorship','1:1'],['Summer Research','Applications open']],
  },
  future: {
    headline: 'The roadmap.',
    body: 'Where QuantHQ is headed.',
    roadmap: ['Research Lab','Open Source Models','Student Fellowships','Conference'],
  },
};
const badgeCls = (b) => {
  if (['Open Source','Live','1:1'].includes(b)) return 'text-[var(--green)]';
  if (['Private','Global','Ongoing'].includes(b)) return 'text-[var(--text-2)]';
  if (['Coming Soon','Weekly','Structured'].includes(b)) return 'text-[var(--accent2)]';
  return 'text-[var(--accent)]';
};
---
<div id="about-tabs" data-tabs={JSON.stringify(tabs)} data-active="mission">
  <div class="flex flex-wrap gap-2 mb-12" id="tab-buttons">
    {tabs.map(t => (
      <button data-tab={t.id} class:list={['px-5 py-2 rounded-full text-[13px] font-medium border transition-colors cursor-pointer', t.id === 'mission' ? 'border-[var(--accent)] text-[var(--accent)] bg-accent-8' : 'border-[var(--border)] text-[var(--text-2)] hover:text-[var(--text-1)] hover:border-[var(--border-hover)]']}>
        {t.label}
      </button>
    ))}
  </div>
  <div id="tab-content" style="opacity:1;transform:translateY(0);transition:opacity 0.3s ease,transform 0.3s ease">
    <h2 class="text-[clamp(32px,5vw,64px)] font-extrabold tracking-[-0.03em] leading-[1.05] max-w-3xl" id="tc-headline"></h2>
    <p class="mt-5 text-[var(--text-2)] max-w-xl leading-relaxed" id="tc-body"></p>
    <div id="tc-extra"></div>
  </div>
</div>
<script>
// re-init tabs on every ClientRouter navigation (module scripts run once)
document.addEventListener('astro:page-load', function(){
  if (!document.getElementById('tab-content')) return; // not on the about page
  const data ={"mission":{"headline":"Building practical AI systems through open research.","body":"QuantHQ exists to make rigorous quantitative research open, collaborative, and reproducible.","stats":[["18","Research Papers"],["4","Open Source Projects"],["200+","Community Members"],["3","Universities"]]},"research":{"headline":"A timeline of what we study.","body":"Our research agenda evolves with the frontier.","timeline":[["2026",["LLM Evaluation","Financial AI","Agent Systems"]],["2027",["Multimodal Market Models","Autonomous Research Agents"]]]},"build":{"headline":"Research that ships.","body":"Everything we learn becomes something you can run.","cards":[["Agent Framework","Open Source"],["Trading Infrastructure","Private"],["Vision Models","Research"],["Cybersecurity","Coming Soon"]]},"community":{"headline":"Intelligence is a team sport.","body":"Where the network lives.","cards":[["Discord","Live"],["Hackathons","Quarterly"],["Reading Groups","Weekly"],["Open Source Contributors","Global"],["Collaborations","Ongoing"]]},"education":{"headline":"Learn by doing research.","body":"Workshops, courses, mentorship, and summer research programs for the next generation of quants.","cards":[["Workshops","Hands-on"],["Courses","Structured"],["Mentorship","1:1"],["Summer Research","Applications open"]]},"future":{"headline":"The roadmap.","body":"Where QuantHQ is headed.","roadmap":["Research Lab","Open Source Models","Student Fellowships","Conference"]}};
  const badgeCls = b => {
    if (['Open Source','Live','1:1'].includes(b)) return 'text-[var(--green)]';
    if (['Private','Global','Ongoing'].includes(b)) return 'text-[var(--text-2)]';
    if (['Coming Soon','Weekly','Structured'].includes(b)) return 'text-[var(--accent2)]';
    return 'text-[var(--accent)]';
  };
  let active = 'mission';
  const btns = document.querySelectorAll('#tab-buttons button');
  const content = document.getElementById('tab-content');
  const headline = document.getElementById('tc-headline');
  const body = document.getElementById('tc-body');
  const extra = document.getElementById('tc-extra');

  function render(id) {
    const t = data[id];
    headline.textContent = t.headline;
    body.textContent = t.body;
    let html = '';
    if (t.stats) {
      html += '<div class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-px bg-[var(--border)] border border-[var(--border)] rounded-lg overflow-hidden">';
      for (const [n,l] of t.stats) html += `<div class="bg-[var(--card-bg)] p-8"><div class="text-4xl font-extrabold tracking-tight">${n}</div><div class="mt-2 text-[11px] uppercase tracking-[0.1em] text-[var(--text-3)] font-medium">${l}</div></div>`;
      html += '</div>';
    }
    if (t.timeline) {
      html += '<div class="mt-12 border-l border-[var(--border)] pl-8 space-y-10">';
      for (const [year,items] of t.timeline) {
        html += `<div><div class="text-2xl font-bold text-[var(--accent)]">${year}</div><ul class="mt-3 space-y-2">`;
        for (const i of items) html += `<li class="text-[var(--text-1)] before:content-['├─'] before:text-[var(--text-4)] before:mr-3 font-mono text-sm">${i}</li>`;
        html += '</ul></div>';
      }
      html += '</div>';
    }
    if (t.cards) {
      html += '<div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">';
      for (const [title,badge] of t.cards) html += `<div class="card p-6"><div class="font-semibold text-[var(--text-1)]">${title}</div><div class="mt-2 text-[10px] uppercase tracking-[0.15em] ${badgeCls(badge)}">${badge}</div></div>`;
      html += '</div>';
    }
    if (t.roadmap) {
      html += '<div class="mt-12 flex flex-col items-start gap-1"><div class="text-sm text-[var(--text-3)] mb-3 font-mono">2026 →</div>';
      for (let i=0;i<t.roadmap.length;i++) {
        html += `<div class="flex flex-col items-start"><div class="card px-6 py-4 font-semibold text-[var(--text-1)]">${t.roadmap[i]}</div>`;
        if (i < t.roadmap.length-1) html += '<div class="text-[var(--text-4)] pl-8 py-1">↓</div>';
        html += '</div>';
      }
      html += '</div>';
    }
    extra.innerHTML = html;
  }

  function switchTab(id) {
    if (id === active) return;
    content.style.opacity = '0';
    content.style.transform = 'translateY(24px)';
    setTimeout(() => {
      active = id;
      render(id);
      history.replaceState(null, '', '#' + id);
      btns.forEach(b => {
        const isAct = b.dataset.tab === id;
        b.className = `px-5 py-2 rounded-full text-[13px] font-medium border transition-colors cursor-pointer ${isAct ? 'border-[var(--accent)] text-[var(--accent)] bg-accent-8' : 'border-[var(--border)] text-[var(--text-2)] hover:text-[var(--text-1)] hover:border-[var(--border-hover)]'}`;
      });
      requestAnimationFrame(() => {
        content.style.opacity = '1';
        content.style.transform = 'translateY(0)';
      });
    }, 150);
  }

  btns.forEach(b => b.addEventListener('click', () => switchTab(b.dataset.tab)));
  window.addEventListener('hashchange', () => {
    const h = location.hash.replace('#','');
    if (data[h]) switchTab(h);
  });
  const init = location.hash.replace('#','');
  if (data[init]) { active = init; render(init); btns.forEach(b => { const isAct = b.dataset.tab===init; b.className = `px-5 py-2 rounded-full text-[13px] font-medium border transition-colors cursor-pointer ${isAct ? 'border-[var(--accent)] text-[var(--accent)] bg-accent-8' : 'border-[var(--border)] text-[var(--text-2)] hover:text-[var(--text-1)] hover:border-[var(--border-hover)]'}`; }); }
  else render('mission');
});
</script>
