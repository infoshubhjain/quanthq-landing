---
// Continuous, static About page. Section ids match the nav "About" dropdown
// links (/about/#mission …) so those still anchor-scroll here.
const sections = [
  {
    id: 'mission', n: '01', label: 'Mission',
    headline: 'Building practical AI systems through open research.',
    body: 'QuantHQ exists to make rigorous quantitative research open, collaborative, and reproducible — a digital institution where quants, engineers, and AI scientists build in public.',
    type: 'stats',
    stats: [['18', 'Research Papers'], ['4', 'Open-Source Projects'], ['200+', 'Community Members'], ['3', 'Universities']],
  },
  {
    id: 'research', n: '02', label: 'Research',
    headline: 'A timeline of what we study.',
    body: 'Our research agenda tracks the frontier — from language-model evaluation and financial AI today to multimodal market models and autonomous research agents next.',
    type: 'timeline',
    timeline: [['2026', ['LLM Evaluation', 'Financial AI', 'Agent Systems']], ['2027', ['Multimodal Market Models', 'Autonomous Research Agents']]],
  },
  {
    id: 'build', n: '03', label: 'Build',
    headline: 'Research that ships.',
    body: 'Everything we learn becomes something you can run. Open frameworks, production infrastructure, and models — released, not shelved.',
    type: 'cards',
    cards: [['Agent Framework', 'Open Source'], ['Trading Infrastructure', 'Private'], ['Vision Models', 'Research'], ['Cybersecurity', 'Coming Soon']],
  },
  {
    id: 'community', n: '04', label: 'Community',
    headline: 'Intelligence is a team sport.',
    body: 'Where the network lives — real-time debate, quarterly hackathons, weekly reading groups, and open collaboration across the globe.',
    type: 'cards',
    cards: [['Discord', 'Live'], ['Hackathons', 'Quarterly'], ['Reading Groups', 'Weekly'], ['Open Source', 'Global'], ['Collaborations', 'Ongoing']],
  },
  {
    id: 'education', n: '05', label: 'Education',
    headline: 'Learn by doing research.',
    body: 'Workshops, courses, mentorship, and summer research programs for the next generation of quants.',
    type: 'cards',
    cards: [['Workshops', 'Hands-on'], ['Courses', 'Structured'], ['Mentorship', '1:1'], ['Summer Research', 'Open']],
  },
  {
    id: 'future', n: '06', label: 'Future',
    headline: 'Where QuantHQ is headed.',
    body: 'A research lab, open models, student fellowships, and a flagship conference — the institution, taking shape.',
    type: 'roadmap',
    roadmap: ['Research Lab', 'Open-Source Models', 'Student Fellowships', 'Annual Conference'],
  },
];
const badgeCls = (b) => {
  if (['Open Source', 'Live', '1:1', 'Open'].includes(b)) return 'green';
  if (['Private', 'Global', 'Ongoing'].includes(b)) return 'muted';
  if (['Coming Soon', 'Weekly', 'Structured', 'Hands-on'].includes(b)) return 'violet';
  return 'accent';
};
---
<div class="about-flow">
  {sections.map((s) => (
    <section id={s.id} class="ab-block rv">
      <div class="ab-head">
        <div class="ab-eyebrow"><span class="ab-num">{s.n}</span><span class="ab-rule"></span>{s.label}</div>
        <h2 class="ab-title display-title">{s.headline}</h2>
      </div>
      <div class="ab-content">
        <p class="ab-body">{s.body}</p>

        {s.type === 'stats' && (
          <div class="ab-stats">
            {s.stats.map(([n, l]) => (
              <div class="ab-stat">
                <div class="ab-stat-n display-figure">{n}</div>
                <div class="ab-stat-l">{l}</div>
              </div>
            ))}
          </div>
        )}

        {s.type === 'timeline' && (
          <div class="ab-timeline">
            {s.timeline.map(([year, items]) => (
              <div class="ab-tl-row">
                <div class="ab-tl-year display-figure">{year}</div>
                <ul class="ab-tl-items">
                  {items.map((i) => <li>{i}</li>)}
                </ul>
              </div>
            ))}
          </div>
        )}

        {s.type === 'cards' && (
          <div class="ab-cards">
            {s.cards.map(([title, badge]) => (
              <div class="ab-card">
                <span class="ab-card-title">{title}</span>
                <span class={`ab-badge ${badgeCls(badge)}`}>{badge}</span>
              </div>
            ))}
          </div>
        )}

        {s.type === 'roadmap' && (
          <ol class="ab-roadmap">
            {s.roadmap.map((step) => (
              <li class="ab-step"><span class="ab-step-dot"></span><span class="ab-step-label">{step}</span></li>
            ))}
          </ol>
        )}
      </div>
    </section>
  ))}
</div>

<style>
  .about-flow { max-width: var(--shell); margin: 0 auto; }
  .ab-block {
    display: grid;
    grid-template-columns: minmax(0, 38%) minmax(0, 1fr);
    gap: 40px 72px;
    padding: 76px 0;
    border-top: 1px solid var(--border);
    scroll-margin-top: 104px;
  }
  .ab-block:first-child { border-top: none; padding-top: 20px; }
  .ab-eyebrow {
    display: flex; align-items: center; gap: 12px;
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--text-3); margin-bottom: 22px;
  }
  .ab-num { color: var(--gold); }
  .ab-rule { width: 24px; height: 1px; background: linear-gradient(90deg, var(--gold), transparent); }
  .ab-title { font-size: clamp(28px, 3.4vw, 46px); line-height: 1.04; color: var(--text); }
  .ab-body { font-size: 16px; line-height: 1.7; color: var(--text-2); max-width: 54ch; margin-bottom: 34px; }

  /* stats */
  .ab-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
  .ab-stat { background: var(--card-bg); padding: 28px; transition: background 0.25s; }
  .ab-stat:hover { background: color-mix(in srgb, var(--text) 3%, var(--card-bg)); }
  .ab-stat-n { font-size: clamp(30px, 3.6vw, 46px); font-weight: 700; letter-spacing: -0.02em; color: var(--text); line-height: 1; }
  .ab-stat-l { margin-top: 10px; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-3); }

  /* timeline */
  .ab-timeline { border-left: 1px solid var(--border); padding-left: 30px; display: flex; flex-direction: column; gap: 34px; }
  .ab-tl-row { position: relative; }
  .ab-tl-row::before {
    content: ''; position: absolute; left: -35px; top: 5px; width: 9px; height: 9px; border-radius: 50%;
    background: var(--gold); box-shadow: 0 0 0 4px color-mix(in srgb, var(--gold) 16%, transparent);
  }
  .ab-tl-year { font-size: 22px; font-weight: 700; color: var(--text); }
  .ab-tl-items { margin-top: 12px; display: flex; flex-direction: column; gap: 9px; }
  .ab-tl-items li { font-family: var(--font-mono); font-size: 13px; color: var(--text-2); }
  .ab-tl-items li::before { content: '├─ '; color: var(--text-4); }
  .ab-tl-items li:last-child::before { content: '└─ '; }

  /* cards */
  .ab-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .ab-card {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    padding: 18px 20px; background: var(--card-bg); border: 1px solid var(--border); border-radius: 10px;
    transition: border-color 0.25s, transform 0.25s;
  }
  .ab-card:hover { border-color: var(--border-hover); transform: translateY(-2px); }
  .ab-card-title { font-size: 14px; font-weight: 600; color: var(--text-1); }
  .ab-badge { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; flex-shrink: 0; }
  .ab-badge.green { color: var(--green); }
  .ab-badge.violet { color: var(--accent2); }
  .ab-badge.accent { color: var(--accent); }
  .ab-badge.muted { color: var(--text-3); }

  /* roadmap */
  .ab-roadmap { list-style: none; }
  .ab-step { display: flex; align-items: center; gap: 16px; padding: 15px 0; position: relative; }
  .ab-step:not(:last-child)::after { content: ''; position: absolute; left: 5px; top: 30px; bottom: -7px; width: 1px; background: var(--border); }
  .ab-step-dot { width: 11px; height: 11px; border-radius: 50%; border: 2px solid var(--gold); flex-shrink: 0; }
  .ab-step-label { font-size: 15px; font-weight: 500; color: var(--text-1); }

  @media (max-width: 860px) {
    .ab-block { grid-template-columns: 1fr; gap: 26px; padding: 56px 0; }
  }
  @media (max-width: 480px) {
    .ab-stats, .ab-cards { grid-template-columns: 1fr; }
  }
</style>
